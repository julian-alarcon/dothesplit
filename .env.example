# Copy to .env and fill in. Do NOT commit .env.
#
# ---------------------------------------------------------------------------
# Critical secrets: generate ONCE, then back them up safely.
# ---------------------------------------------------------------------------
# These three keys protect every email and password in the database. If you
# lose them you cannot recover your data; if they leak an attacker can
# decrypt every email and forge password hashes.
#
# Generate each one with:
#
#   openssl rand -base64 32
#
# Paste each output below. They MUST stay the same across container rebuilds
# and host reinstalls - store a copy in your password manager or backup vault.
EMAIL_ENC_KEY=
EMAIL_HMAC_KEY=
PASSWORD_PEPPER=

# Postgres password. Generate with `openssl rand -base64 24` or pick something
# strong. Resettable later (you can rotate it) but the database has to be
# reachable to do so, so don't lose this one either.
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Connection settings: adjust if you move services to other hosts.
# ---------------------------------------------------------------------------
POSTGRES_USER=dts
POSTGRES_DB=dts
DATABASE_URL=postgres://dts:CHANGE_ME@postgres:5432/dts?sslmode=disable

# API
API_HTTP_ADDR=:8080
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Cookies / sessions
# LAN profile: HTTP only, so Secure must be false. See README for the HTTPS deviation.
COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Web
PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL_INTERNAL=http://api:8080
