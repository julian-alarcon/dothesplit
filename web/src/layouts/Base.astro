---
import "@/styles/global.css";
import Avatar from "@/components/Avatar.astro";
interface Props {
  title: string;
}
const { title } = Astro.props;
const user = Astro.locals.user;
// Baked in at build time by the Dockerfile; defaults to "dev" when building
// locally without a git context. Short SHA already (handled by the build args)
// but fall back to trimming here so we never render a 40-char string.
const buildCommit = (process.env.BUILD_COMMIT ?? "dev").slice(0, 12);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · DoTheSplit</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="border-b border-neutral-200 bg-white/70 backdrop-blur dark:border-neutral-800 dark:bg-neutral-900/70">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <a href={user ? "/groups" : "/"} class="text-lg font-semibold">DoTheSplit</a>
        {user ? (
          <div class="flex items-center gap-3 text-sm">
            <a
              href="/account"
              class="flex items-center gap-2 rounded-md text-neutral-700 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:text-neutral-300 dark:focus-visible:ring-neutral-500"
            >
              <Avatar
                userId={user.id}
                displayName={user.display_name}
                hasAvatar={user.has_avatar}
                avatarUpdatedAt={user.avatar_updated_at}
                size={24}
              />
              <span>{user.display_name}</span>
            </a>
            <form method="POST" action="/api/logout">
              <button
                class="rounded-md border border-neutral-300 px-3 py-1 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:border-neutral-700 dark:hover:bg-neutral-800 dark:focus-visible:ring-neutral-500"
                type="submit"
              >
                Log out
              </button>
            </form>
          </div>
        ) : (
          <nav class="flex gap-4 text-sm">
            <a href="/login" class="hover:underline">Log in</a>
            <a href="/register" class="hover:underline">Register</a>
          </nav>
        )}
      </div>
    </header>
    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-6">
      <slot />
    </main>
    <footer class="border-t border-neutral-200 bg-white/70 py-3 text-center text-xs text-neutral-500 dark:border-neutral-800 dark:bg-neutral-900/70 dark:text-neutral-400">
      <div class="mx-auto max-w-5xl px-4">
        DoTheSplit ·
        {buildCommit === "dev" ? (
          <span>build <code class="font-mono">dev</code></span>
        ) : (
          <span>
            build <a
              href={`https://github.com/julian-alarcon/dothesplit/commit/${buildCommit}`}
              class="font-mono hover:underline"
              rel="noopener noreferrer"
              target="_blank"
            >{buildCommit}</a>
          </span>
        )}
      </div>
    </footer>
  </body>
</html>
