---
import { Font } from "astro:assets";
import "@/styles/global.css";
import Avatar from "@/components/Avatar.astro";
import FaIcon from "@/components/FaIcon.astro";
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";
interface Props {
  title: string;
  // Opt-in wider cap for pages that genuinely benefit from a multi-column
  // layout at ≥1024px (e.g. the group dashboard's Balances | Activity |
  // Add expense triptych). Default stays max-w-3xl (768px) - see the
  // single-column rule in CLAUDE.md.
  wide?: boolean;
  // Optional "Back to X" link rendered in its own max-w-6xl row between the
  // header and main, so its left edge anchors next to the brand regardless
  // of whether the page uses the default or the wide cap.
  back?: { href: string; label: string };
}
const { title, wide = false, back } = Astro.props;
const containerClass = wide ? "max-w-6xl" : "max-w-3xl";
const user = Astro.locals.user;
// Baked in at build time by the Dockerfile; defaults to "dev" when building
// locally without a git context. Short SHA already (handled by the build args)
// but fall back to trimming here so we never render a 40-char string.
const buildCommit = (process.env.BUILD_COMMIT ?? "dev").slice(0, 12);
// If the user has an explicit stored timezone override, surface it on <html>
// so the client-side reformatter pins to it. Without an override, the client
// is free to use its own device-detected zone (which it always knows).
const tzOverride = user?.timezone ?? null;
---

<!doctype html>
<html lang="en" data-tz-override={tzOverride ?? undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · DoTheSplit</title>
    <Font cssVariable="--font-inter" preload />
    {/* Theme boot script: applies the stored theme before paint. Loaded as
        an external module (not <script is:inline>) so Vite emits it as a
        hashed asset that the strict CSP `script-src 'self'` allows. Astro
        does not auto-hash raw <script is:inline> blocks placed in .astro
        sources, so inlining the body would silently get blocked. */}
    <script src="/src/scripts/theme-boot.ts"></script>
    <script src="/src/scripts/tz-cookie.ts"></script>
    <script src="/src/scripts/local-time.ts"></script>
    <script src="/src/scripts/dialog-scroll-lock.ts"></script>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="border-b border-border bg-card/70 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <a href={user ? "/groups" : "/"} class="text-lg font-semibold">DoTheSplit</a>
        {user ? (
          <div class="flex items-center gap-3">
            {user.is_admin && (
              <a
                href="/admin"
                class="inline-flex items-center gap-1 rounded-md border border-amber-400/60 bg-amber-50 px-2 py-1 text-xs font-medium text-amber-900 hover:bg-amber-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 dark:border-amber-500/60 dark:bg-amber-950/40 dark:text-amber-200 dark:hover:bg-amber-900/40"
                aria-label="Admin"
              >
                <FaIcon name="shield-halved" />
                <span>Admin</span>
              </a>
            )}
            <a
              href="/account"
              class="flex items-center gap-2 rounded-md text-sm text-neutral-700 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:text-neutral-300 dark:focus-visible:ring-neutral-500"
            >
              <Avatar
                userId={user.id}
                displayName={user.display_name}
                hasAvatar={user.has_avatar}
                avatarUpdatedAt={user.avatar_updated_at}
                size={24}
              />
              <span>{user.display_name}</span>
            </a>
          </div>
        ) : (
          <nav class="flex gap-4 text-sm">
            <a href="/login" class="hover:underline">Log in</a>
            <a href="/register" class="hover:underline">Register</a>
          </nav>
        )}
      </div>
    </header>
    {back && (
      <div class="mx-auto w-full max-w-6xl px-2 pt-3">
        <a href={back.href} class="btn-secondary btn-sm self-start">
          <FaIcon name="arrow-left-long" />
          <span>Back to {back.label}</span>
        </a>
      </div>
    )}
    <main class:list={["mx-auto w-full flex-1 px-2 py-2", containerClass]}>
      <slot />
    </main>
    <footer class="border-t border-border bg-card/70 py-3 text-xs text-muted-foreground">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-4 gap-y-2 px-4">
        <span>
          DoTheSplit ·
          {buildCommit === "dev" ? (
            <span>build <code class="font-mono">dev</code></span>
          ) : (
            <span>
              build <a
                href={`https://github.com/julian-alarcon/dothesplit/commit/${buildCommit}`}
                class="font-mono hover:underline"
                rel="noopener noreferrer"
                target="_blank"
              >{buildCommit}</a>
            </span>
          )}
          · <a href="/credits" class="hover:underline">Credits</a>
        </span>
        <ThemeSwitcher />
      </div>
    </footer>
  </body>
</html>
