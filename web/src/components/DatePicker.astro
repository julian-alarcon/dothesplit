---
// Shared date-picker UI. The trigger is a calendar icon-button with the
// currently-selected day rendered inside it; clicking opens a <dialog> with
// a custom month-grid calendar. Writes YYYY-MM-DD into a hidden input named
// `name` so the SSR handler stays unchanged.
//
// Variants:
//   - "default": full-width pill with the icon + formatted date label.
//   - "compact": just the icon-button, sized to sit next to a sibling button.
//
// All dynamic logic lives in web/src/scripts/date-picker.ts, which the page
// importing this component must also include.

interface Props {
  name: string;
  value: string; // YYYY-MM-DD
  caption?: string; // optional secondary line (only rendered for default variant)
  variant?: "default" | "compact";
  ariaLabel?: string; // override label for the compact icon-only button
  // When provided, the modal includes a "Repeat" dropdown and the trigger
  // shows a small "Repeats {label}" badge. The chosen value is written to a
  // hidden input named `${name}_cadence` so the SSR handler can pick it up.
  // Empty string = no repeat.
  cadenceName?: string;
  cadenceValue?: string; // initial cadence (empty = none)
  // First day of the week to render in the grid: 0 = Sunday, 1 = Monday.
  // Sourced from the per-user preference (Astro.locals.user.week_start).
  weekStart?: 0 | 1;
}

const {
  name,
  value,
  caption,
  variant = "default",
  ariaLabel = "Pick date",
  cadenceName,
  cadenceValue = "",
  weekStart = 1,
} = Astro.props as Props;
const day = Number(value.slice(8, 10)) || 1;
const isCompact = variant === "compact";
const showCadence = !!cadenceName;
const titleId = `dp-title-${name}`;
const focusRing =
  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:focus-visible:ring-neutral-500";
---

<div
  class:list={["relative", isCompact ? "inline-flex items-center gap-2" : "flex flex-col gap-1"]}
  data-date-picker
  data-input-name={name}
  data-week-start={String(weekStart)}
>
  <input type="hidden" name={name} value={value} data-date-value />
  {showCadence && (
    <input type="hidden" name={cadenceName} value={cadenceValue} data-cadence-value />
  )}

  {isCompact ? (
    <Fragment>
      <button
        type="button"
        data-date-open
        aria-label={ariaLabel}
        title={ariaLabel}
        class:list={[
          "inline-flex h-9 w-9 items-center justify-center rounded-md border border-neutral-300 bg-white hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800",
          focusRing,
        ]}
      >
        <span class="relative block h-7 w-7" aria-hidden="true">
          <svg viewBox="0 0 28 28" class="absolute inset-0 h-7 w-7 text-neutral-600 dark:text-neutral-300" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="6" width="22" height="19" rx="2.5" />
            <line x1="3" y1="11" x2="25" y2="11" />
            <line x1="9" y1="3.5" x2="9" y2="7.5" stroke-linecap="round" />
            <line x1="19" y1="3.5" x2="19" y2="7.5" stroke-linecap="round" />
          </svg>
          <span
            data-date-day
            class="absolute inset-x-0 top-[12px] flex h-[14px] items-center justify-center text-[10px] font-semibold leading-none text-neutral-700 dark:text-neutral-200"
          >{day}</span>
        </span>
      </button>
      {showCadence && (
        <span
          data-cadence-badge
          class="hidden text-xs text-neutral-500 dark:text-neutral-400"
        ></span>
      )}
    </Fragment>
  ) : (
    <div class="flex items-center justify-between gap-3 rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
      <button
        type="button"
        data-date-open
        class:list={["flex items-center gap-2 text-left text-sm hover:opacity-80 rounded-md", focusRing]}
      >
        <span class="relative inline-block h-7 w-7" aria-hidden="true">
          <svg viewBox="0 0 28 28" class="absolute inset-0 h-7 w-7 text-neutral-500 dark:text-neutral-400" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="6" width="22" height="19" rx="2.5" />
            <line x1="3" y1="11" x2="25" y2="11" />
            <line x1="9" y1="3.5" x2="9" y2="7.5" stroke-linecap="round" />
            <line x1="19" y1="3.5" x2="19" y2="7.5" stroke-linecap="round" />
          </svg>
          <span
            data-date-day
            class="absolute inset-x-0 top-[12px] flex h-[14px] items-center justify-center text-[10px] font-semibold leading-none text-neutral-700 dark:text-neutral-200"
          >{day}</span>
        </span>
        <span data-date-label class="font-medium"></span>
      </button>
    </div>
  )}
  {caption && !isCompact && (
    <span class="text-xs text-neutral-500">{caption}</span>
  )}

  <dialog
    data-date-dialog
    aria-modal="true"
    aria-labelledby={titleId}
    class="fixed inset-0 m-auto w-full max-w-sm rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
  >
    <div class="flex flex-col gap-4 p-5">
      <div class="flex items-center justify-between">
        <h3 id={titleId} class="text-lg font-medium">Pick date</h3>
        <button
          type="button"
          data-date-cancel
          aria-label="Close"
          title="Close"
          class:list={["rounded-md px-2 py-1 text-sm text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800", focusRing]}
        >
          ✕
        </button>
      </div>

      <div class="flex items-center justify-between">
        <h4 class="text-sm font-medium" data-cal-title>—</h4>
        <div class="flex items-center gap-2">
          <button
            type="button"
            data-cal-prev
            aria-label="Previous month"
            title="Previous month"
            class:list={[
              "inline-flex h-9 w-9 items-center justify-center rounded-md border border-neutral-300 text-neutral-600 hover:bg-neutral-50 dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-800",
              focusRing,
            ]}
          >
            <svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="10 3 5 8 10 13" />
            </svg>
          </button>
          <button
            type="button"
            data-cal-next
            aria-label="Next month"
            title="Next month"
            class:list={[
              "inline-flex h-9 w-9 items-center justify-center rounded-md border border-neutral-300 text-neutral-600 hover:bg-neutral-50 dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-800",
              focusRing,
            ]}
          >
            <svg viewBox="0 0 16 16" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 3 11 8 6 13" />
            </svg>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-7 gap-1 text-center text-xs text-neutral-500" data-cal-weekdays></div>
      <div class="grid grid-cols-7 gap-1" role="grid" aria-labelledby={titleId} data-cal-grid></div>

      <div class="flex flex-col gap-3 border-t border-neutral-200 pt-3 dark:border-neutral-800">
        <div class="flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-date-today
            class:list={[
              "rounded-md border border-neutral-300 bg-white px-3 py-1.5 text-sm hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800",
              focusRing,
            ]}
          >
            Today
          </button>
          {showCadence && (
            <label class="flex items-center gap-1.5 text-sm">
              <span class="text-neutral-500">Repeat</span>
              <select
                data-cadence-select
                class:list={[
                  "rounded-md border border-neutral-300 bg-white px-2 py-1 text-sm dark:border-neutral-700 dark:bg-neutral-950",
                  focusRing,
                ]}
              >
                <option value="" selected={cadenceValue === ""}>Never</option>
                <option value="daily" selected={cadenceValue === "daily"}>Daily</option>
                <option value="weekly" selected={cadenceValue === "weekly"}>Weekly</option>
                <option value="biweekly" selected={cadenceValue === "biweekly"}>Every 2 weeks</option>
                <option value="monthly" selected={cadenceValue === "monthly"}>Monthly</option>
                <option value="yearly" selected={cadenceValue === "yearly"}>Yearly</option>
              </select>
            </label>
          )}
        </div>
        <div class="flex items-center justify-end gap-2">
          <button
            type="button"
            data-date-cancel
            class:list={[
              "rounded-md border border-neutral-300 bg-white px-3 py-1.5 text-sm hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800",
              focusRing,
            ]}
          >
            Cancel
          </button>
          <button
            type="button"
            data-date-done
            class:list={[
              "rounded-md bg-neutral-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300",
              focusRing,
            ]}
          >
            Done
          </button>
        </div>
      </div>
    </div>
  </dialog>
</div>
