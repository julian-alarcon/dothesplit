---
interface Props {
  class?: string;
}
const { class: className = "h-4 w-4" } = Astro.props as Props;
---

<svg
  viewBox="0 0 16 16"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <polyline points="10 3 5 8 10 13" />
</svg>
