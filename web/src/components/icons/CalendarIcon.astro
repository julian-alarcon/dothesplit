---
// Calendar glyph used by DatePicker. The day number is rendered separately
// (text overlay positioned by the caller) so the icon stays purely visual.

interface Props {
  class?: string;
}
const { class: className = "h-7 w-7" } = Astro.props as Props;
---

<svg
  viewBox="0 0 28 28"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  aria-hidden="true"
>
  <rect x="3" y="6" width="22" height="19" rx="2.5" />
  <line x1="3" y1="11" x2="25" y2="11" />
  <line x1="9" y1="3.5" x2="9" y2="7.5" stroke-linecap="round" />
  <line x1="19" y1="3.5" x2="19" y2="7.5" stroke-linecap="round" />
</svg>
