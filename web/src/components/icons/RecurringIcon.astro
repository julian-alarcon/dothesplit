---
// Circular-arrow "repeat" glyph. Matches the ↻ symbol used in the
// recurring-expense badges so the header button reads as the same concept.
//
// Decorative-by-default (aria-hidden="true"); the parent is expected to
// supply the accessible name via text content or aria-label.

interface Props {
  class?: string;
}
const { class: className = "h-4 w-4" } = Astro.props as Props;
---

<svg
  viewBox="0 0 16 16"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d="M2.5 8a5.5 5.5 0 0 1 9.4-3.9" />
  <polyline points="12 1.5 12 4.5 9 4.5" />
  <path d="M13.5 8a5.5 5.5 0 0 1-9.4 3.9" />
  <polyline points="4 14.5 4 11.5 7 11.5" />
</svg>
