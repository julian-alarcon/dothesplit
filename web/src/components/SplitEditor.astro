---
import FaIcon from "@/components/FaIcon.astro";

// Shared split-configuration UI. Renders a tappable summary row that opens
// a <dialog> for choosing split mode (equal / exact / percent) across group
// members. The hidden input[name="splits_json"] is read by the SSR handler.
//
// All dynamic logic lives in web/src/scripts/split-editor.ts, which the page
// importing this component must also include.

interface Member {
  user_id: string;
  display_name: string;
}

interface InitialSplit {
  user_id: string;
  share_cents: number;
}

interface DefaultSplitEntry {
  user_id: string;
  basis_points: number;
}

interface Props {
  members: Member[];
  currency: string;
  currentUserId?: string;
  initialSplits?: InitialSplit[];
  defaultSplit?: DefaultSplitEntry[];
}

const {
  members,
  currency,
  currentUserId,
  initialSplits = [],
  defaultSplit = [],
} = Astro.props as Props;

const membersJSON = JSON.stringify(
  members.map((m) => ({ id: m.user_id, name: m.display_name })),
);
const initialJSON = JSON.stringify(initialSplits);
const defaultJSON = JSON.stringify(defaultSplit);

const titleId = "split-title";
const focusRing =
  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:focus-visible:ring-neutral-500";
---

<div
  class="flex flex-col gap-2"
  data-split-editor
  data-currency={currency}
  data-current-user={currentUserId ?? ""}
  data-members={membersJSON}
  data-initial={initialJSON}
  data-default={defaultJSON}
>
  <input type="hidden" name="splits_json" value="" />

  <button
    type="button"
    data-split-open
    aria-label="Configure split"
    class={`flex w-full items-center justify-between gap-3 rounded-md border border-neutral-300 bg-white px-3 py-2 text-left text-sm hover:bg-neutral-50 ${focusRing} dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800`}
  >
    <span class="min-w-0 flex-1 text-neutral-700 dark:text-neutral-300" data-split-summary>
      Split equally between {members.length} member{members.length === 1 ? "" : "s"}
    </span>
    <span class="flex shrink-0 items-center gap-1.5 text-neutral-500 dark:text-neutral-400">
      <span class="hidden sm:inline">Configure</span>
      <FaIcon name="chevron-right" />
    </span>
  </button>

  <dialog
    data-split-dialog
    aria-modal="true"
    aria-labelledby={titleId}
    class="fixed inset-0 m-auto w-[calc(100%-2rem)] max-w-md rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
  >
    <div class="flex flex-col gap-4 p-5">
      <div class="flex items-center justify-between">
        <h3 id={titleId} class="text-lg font-medium">Configure split</h3>
        <button
          type="button"
          data-split-cancel
          aria-label="Close"
          title="Close"
          class={`rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-100 ${focusRing} dark:text-neutral-400 dark:hover:bg-neutral-800`}
        >
          <FaIcon name="xmark" size={14} />
        </button>
      </div>

      <fieldset class="flex gap-4 text-sm">
        <legend class="sr-only">Split mode</legend>
        <label class={`flex items-center gap-1.5 rounded-md ${focusRing}`}>
          <input type="radio" name="split_mode" value="equal" checked class="accent-neutral-900 dark:accent-neutral-100" />
          <span>Equal</span>
        </label>
        <label class={`flex items-center gap-1.5 rounded-md ${focusRing}`}>
          <input type="radio" name="split_mode" value="exact" class="accent-neutral-900 dark:accent-neutral-100" />
          <span>Exact amounts</span>
        </label>
        <label class={`flex items-center gap-1.5 rounded-md ${focusRing}`}>
          <input type="radio" name="split_mode" value="percent" class="accent-neutral-900 dark:accent-neutral-100" />
          <span>Percentage</span>
        </label>
      </fieldset>

      <ul class="flex max-h-80 flex-col gap-1 overflow-auto">
        {members.map((m) => (
          <li data-split-row={m.user_id} class="flex items-center gap-2 rounded-md px-2 py-1.5 hover:bg-neutral-50 dark:hover:bg-neutral-950">
            <input
              type="checkbox"
              checked
              class={`shrink-0 accent-neutral-900 ${focusRing} dark:accent-neutral-100`}
              aria-label={`Include ${m.display_name}`}
            />
            <span class="min-w-0 flex-1 truncate text-sm" data-split-label>{m.display_name}</span>
            <input
              type="number"
              step="0.01"
              min="0"
              data-split-value
              class={`field-input-num w-20 shrink-0 ${focusRing}`}
            />
            <span class="w-16 shrink-0 text-right font-mono text-xs text-neutral-600 dark:text-neutral-400" data-split-preview>-</span>
          </li>
        ))}
      </ul>

      <div class="flex items-center justify-between gap-3 border-t border-neutral-200 pt-3 text-sm dark:border-neutral-800">
        <span class="text-neutral-600 dark:text-neutral-400" data-split-remaining></span>
        <span class="font-mono" data-split-total></span>
      </div>

      <p class="min-h-[1.25em] text-xs text-red-600 dark:text-red-400" data-split-error></p>

      <div class="flex justify-end gap-2">
        <button type="button" data-split-cancel class="btn-secondary btn-sm">Cancel</button>
        <button type="button" data-split-done class="btn-primary btn-sm">Done</button>
      </div>
    </div>
  </dialog>
</div>
