---
// Shared confirmation modal. Renders a hidden <dialog> identified by `id`.
// Wire any trigger button on the page with:
//   <button type="button" data-confirm-open={id}>Delete</button>
// The button must live inside the <form> that should be submitted on confirm.
// The script intercepts the click, opens this dialog, and on Confirm calls
// form.requestSubmit() on the trigger's closest ancestor form.
//
// All dynamic logic lives in web/src/scripts/confirm-dialog.ts, which the
// importing page must also include.

interface Props {
  id: string;
  title: string;
  message: string;
  confirmLabel: string;
  // "danger" → red filled button (destructive); "primary" → black/white filled.
  confirmVariant?: "danger" | "primary";
  cancelLabel?: string;
}

const {
  id,
  title,
  message,
  confirmLabel,
  confirmVariant = "danger",
  cancelLabel = "Cancel",
} = Astro.props as Props;

const titleId = `${id}-title`;
const msgId = `${id}-msg`;

const focusRing =
  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:focus-visible:ring-neutral-500";

const confirmCls =
  confirmVariant === "danger"
    ? "rounded-md border border-red-600 bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700"
    : "rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300";
---

<dialog
  id={id}
  data-confirm-dialog
  aria-modal="true"
  aria-labelledby={titleId}
  aria-describedby={msgId}
  class="fixed inset-0 m-auto w-full max-w-sm rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
>
  <div class="flex flex-col gap-4 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 id={titleId} class="text-lg font-medium">{title}</h3>
      <button
        type="button"
        data-confirm-cancel
        aria-label="Close"
        title="Close"
        class:list={[
          "rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-100 dark:text-neutral-400 dark:hover:bg-neutral-800",
          focusRing,
        ]}
      >
        ✕
      </button>
    </div>
    <p id={msgId} class="text-sm text-neutral-700 dark:text-neutral-300">{message}</p>
    <div class="flex flex-col gap-2 sm:flex-row sm:justify-end">
      <button
        type="button"
        data-confirm-cancel
        class:list={[
          "rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-medium hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800",
          focusRing,
        ]}
      >
        {cancelLabel}
      </button>
      <button
        type="button"
        data-confirm-accept
        class:list={[confirmCls, focusRing]}
      >
        {confirmLabel}
      </button>
    </div>
  </div>
</dialog>
