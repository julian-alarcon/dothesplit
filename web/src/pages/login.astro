---
import Base from "@/layouts/Base.astro";
const showError = Astro.url.searchParams.get("error") === "1";
---

<Base title="Log in">
  <div class="mx-auto max-w-sm">
    <h1 class="mb-6 text-2xl font-semibold">Log in</h1>
    {showError && (
      <p
        role="status"
        aria-live="polite"
        class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
      >
        Invalid email or password.
      </p>
    )}
    <form method="POST" action="/api/login" class="flex flex-col gap-3 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <label class="field">
        <input type="email" name="email" required placeholder=" " class="field-input" />
        <span class="field-label" data-required>Email</span>
      </label>
      <label class="field">
        <input type="password" name="password" required minlength="10" placeholder=" " class="field-input" />
        <span class="field-label" data-required>Password</span>
      </label>
      <button type="submit" class="btn-primary mt-2 self-end">Log in</button>
    </form>
    <p class="mt-4 text-sm text-neutral-700 dark:text-neutral-300">
      No account? <a href="/register" class="rounded-md underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:focus-visible:ring-neutral-500">Register</a>.
    </p>
  </div>
</Base>
