---
import Base from "@/layouts/Base.astro";

const email = Astro.url.searchParams.get("email") ?? "";
// Standalone visits with no ?email= are meaningless: there's no flow in
// progress to verify. Bounce visitors back to login (or /groups if they're
// already authenticated) instead of showing an empty form.
if (!email) {
  return Astro.redirect(Astro.locals.user ? "/groups" : "/login");
}
const showError = Astro.url.searchParams.get("error");
const showResent = Astro.url.searchParams.get("resent") === "1";
const errorMsg =
  showError === "invalid"
    ? "That code didn't match. Try again or request a new one."
    : showError === "expired"
      ? "Your code expired. Tap 'Send a new code' to receive a fresh one."
      : showError === "rate_limited"
        ? "Too many attempts. Request a new code and try again."
        : showError
          ? "Could not verify. Please try again."
          : null;
---

<Base title="Verify your email">
  <div class="mx-auto max-w-sm">
    <h1 class="mb-2 text-2xl font-semibold">Check your inbox</h1>
    <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
      We sent a 6-digit code to <strong>{email || "your email"}</strong>. Paste it below to finish creating your account.
    </p>

    {errorMsg && (
      <p
        role="status"
        aria-live="polite"
        class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
      >
        {errorMsg}
      </p>
    )}
    {showResent && (
      <p
        role="status"
        aria-live="polite"
        class="mb-4 rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200"
      >
        New code sent. It may take a moment to arrive.
      </p>
    )}

    <form
      method="POST"
      action="/api/verify"
      class="flex flex-col gap-3 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
    >
      <input type="hidden" name="email" value={email} />
      <label class="field">
        <input
          name="code"
          required
          inputmode="numeric"
          autocomplete="one-time-code"
          pattern="[0-9]{6}"
          maxlength="6"
          minlength="6"
          placeholder=" "
          class="field-input tracking-[0.4em] text-center"
          autofocus
        />
        <span class="field-label" data-required>6-digit code</span>
      </label>
      <p class="field-error">Enter the 6-digit code from your email</p>
      <button type="submit" class="btn-primary mt-2 self-end">Verify</button>
    </form>

    <form method="POST" action="/api/verify-resend" class="mt-4">
      <input type="hidden" name="email" value={email} />
      <button
        type="submit"
        class="rounded-md text-sm underline text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:focus-visible:ring-neutral-500"
      >
        Send a new code
      </button>
    </form>
  </div>
</Base>
