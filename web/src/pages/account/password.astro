---
import Base from "@/layouts/Base.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const error = Astro.url.searchParams.get("error");
const recoverState = Astro.url.searchParams.get("recover");

const errorMsg =
  error === "current"
    ? "Type your current password."
    : error === "length"
      ? "New password must be at least 10 characters."
      : error === "mismatch"
        ? "The new password and the confirmation don't match."
        : error === "wrong_current"
          ? "Your current password is incorrect."
          : error
            ? "Could not change the password. Please try again."
            : null;
---

<Base title="Password" back={{ href: "/account", label: "Account" }}>
  <div class="mx-auto flex max-w-xl flex-col gap-3">
    <h1 class="text-2xl font-semibold">Change your password or recover your current one.</h1>

    {errorMsg && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
      >
        {errorMsg}
      </p>
    )}
    {recoverState === "sent" && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200"
      >
        We've sent a 6-digit code to your email. Open the reset page to enter it.
      </p>
    )}

    <form
      method="POST"
      action="/api/me-password"
      class="flex flex-col gap-3 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
    >
      <label class="field">
        <input
          type="password"
          name="old_password"
          required
          autocomplete="current-password"
          placeholder=" "
          class="field-input"
        />
        <span class="field-label" data-required>Current password</span>
      </label>
      <p class="text-xs text-neutral-600 dark:text-neutral-400 -mt-1">
        You must provide your current password in order to change it.
      </p>

      <label class="field">
        <input
          type="password"
          name="new_password"
          required
          minlength="10"
          autocomplete="new-password"
          placeholder=" "
          class="field-input"
          data-new-password
        />
        <span class="field-label" data-required>New password</span>
      </label>
      <p class="field-error">Password must be at least 10 characters</p>

      <label class="field">
        <input
          type="password"
          name="password_confirmation"
          required
          minlength="10"
          autocomplete="new-password"
          placeholder=" "
          class="field-input"
          data-confirm-password
        />
        <span class="field-label" data-required>Password confirmation</span>
      </label>
      <p class="field-error">Both passwords must match</p>

      <div class="flex flex-wrap justify-end gap-2 pt-2">
        <button
          type="submit"
          form="recover-form"
          class="btn-secondary"
        >
          Recover password by email
        </button>
        <button type="submit" class="btn-primary">Save password</button>
      </div>
    </form>

    <form id="recover-form" method="POST" action="/api/me-password-recover" class="hidden"></form>
  </div>

  <script>
    // Live confirmation match: setCustomValidity flips :user-invalid on the
    // confirmation input, which the existing .field-error CSS already turns
    // red. No JS submit interception - leaves the native HTML5 validation
    // path intact, same as the rest of the forms in this app.
    const newPwd = document.querySelector<HTMLInputElement>("[data-new-password]");
    const confirmPwd = document.querySelector<HTMLInputElement>("[data-confirm-password]");
    if (newPwd && confirmPwd) {
      const sync = () => {
        confirmPwd.setCustomValidity(
          confirmPwd.value === newPwd.value ? "" : "Both passwords must match",
        );
      };
      newPwd.addEventListener("input", sync);
      confirmPwd.addEventListener("input", sync);
    }
  </script>
</Base>
