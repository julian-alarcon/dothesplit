---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import ConfirmDialog from "@/components/ConfirmDialog.astro";
const PREVIEW_SIZE = 64;

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const err = Astro.url.searchParams.get("error");
const ok = Astro.url.searchParams.get("ok");

const errorMessages: Record<string, string> = {
  rename: "Could not update your display name.",
  password: "Could not change your password. Check your old password and try again.",
  avatar: "Could not save that avatar. It must be a valid image the browser can read.",
  prefs: "Could not update your preferences.",
};
const okMessages: Record<string, string> = {
  rename: "Display name updated.",
  password: "Password changed.",
  avatar: "Avatar updated.",
  avatar_cleared: "Avatar removed.",
  prefs: "Preferences updated.",
};
---

<Base title="Account settings">
  <div class="mx-auto flex max-w-2xl flex-col gap-2">
    <div class="flex items-center gap-4">
      <Avatar
        userId={user.id}
        displayName={user.display_name}
        hasAvatar={user.has_avatar}
        avatarUpdatedAt={user.avatar_updated_at}
        size={56}
      />
      <div>
        <h1 class="text-2xl font-semibold">{user.display_name}</h1>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">{user.email}</p>
      </div>
    </div>

    {err && errorMessages[err] && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
      >
        {errorMessages[err]}
      </p>
    )}
    {ok && okMessages[ok] && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200"
      >
        {okMessages[ok]}
      </p>
    )}

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Display name</h2>
      <form method="POST" action="/api/me-rename" class="flex flex-col gap-3">
        <label class="field">
          <input
            name="display_name"
            required
            minlength="1"
            maxlength="80"
            value={user.display_name}
            placeholder=" "
            class="field-input"
          />
          <span class="field-label" data-required>Display name</span>
        </label>
        <p class="field-error">Required</p>
        <div class="flex justify-end">
          <button type="submit" class="btn-primary">Save name</button>
        </div>
      </form>
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Avatar</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Pick any image. We'll pixelate it in your browser to a fun 8×8 mosaic and upload only that 64-pixel tile.
      </p>

      <form
        method="POST"
        action="/api/me-avatar"
        class="flex flex-col gap-3"
        data-avatar-form
      >
        <div class="flex items-center gap-4">
          <div
            class="shrink-0 overflow-hidden rounded border border-neutral-300 dark:border-neutral-700"
            style={`width:${PREVIEW_SIZE}px;height:${PREVIEW_SIZE}px`}
            data-avatar-preview-slot
          >
            {user.has_avatar ? (
              <img
                src={`/api/user-avatar?id=${user.id}&v=${encodeURIComponent(user.avatar_updated_at ?? "")}`}
                alt="Avatar preview"
                width={PREVIEW_SIZE}
                height={PREVIEW_SIZE}
                style={`width:${PREVIEW_SIZE}px;height:${PREVIEW_SIZE}px;display:block`}
              />
            ) : (
              <Avatar
                userId={user.id}
                displayName={user.display_name}
                hasAvatar={false}
                size={PREVIEW_SIZE}
                class="!rounded-none"
              />
            )}
          </div>
          <input
            type="file"
            accept="image/*"
            data-avatar-file
            class="block w-full text-sm file:mr-3 file:rounded-md file:border-0 file:bg-neutral-900 file:px-3 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-neutral-700 dark:file:bg-neutral-100 dark:file:text-neutral-900 dark:hover:file:bg-neutral-300"
          />
        </div>
        <input type="hidden" name="png_base64" data-avatar-b64 />
        <div class="flex justify-end gap-2">
          {user.has_avatar && (
            <button type="submit" form="avatar-clear-form" class="btn-secondary">Remove avatar</button>
          )}
          <button type="submit" data-avatar-submit class="btn-primary">Save avatar</button>
        </div>
      </form>

      {user.has_avatar && (
        <form id="avatar-clear-form" method="POST" action="/api/me-avatar-clear" class="hidden" />
      )}
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Change password</h2>
      <form method="POST" action="/api/me-password" class="flex flex-col gap-3">
        <label class="field">
          <input
            type="password"
            name="old_password"
            required
            placeholder=" "
            class="field-input"
          />
          <span class="field-label" data-required>Current password</span>
        </label>
        <p class="field-error">Required</p>
        <label class="field">
          <input
            type="password"
            name="new_password"
            required
            minlength="10"
            placeholder=" "
            class="field-input"
          />
          <span class="field-label" data-required>New password (min 10 characters)</span>
        </label>
        <p class="field-error">Password must be at least 10 characters</p>
        <div class="flex justify-end">
          <button type="submit" class="btn-primary">Change password</button>
        </div>
      </form>
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Preferences</h2>
      <form method="POST" action="/api/me-preferences" class="flex flex-col gap-3">
        <label class="field-select-row">
          <span>Week starts on</span>
          <select name="week_start" class="field-select">
            <option value="1" selected={user.week_start === 1}>Monday</option>
            <option value="0" selected={user.week_start === 0}>Sunday</option>
          </select>
        </label>
        <p class="-mt-1 text-xs text-neutral-600 dark:text-neutral-400">Used by the calendar in date pickers across the app.</p>
        <div class="flex justify-end">
          <button type="submit" class="btn-primary">Save preferences</button>
        </div>
      </form>
    </section>

    <section class="flex flex-col gap-3 rounded-md border border-neutral-200 bg-white p-4 sm:flex-row sm:items-center sm:justify-between dark:border-neutral-800 dark:bg-neutral-900">
      <div>
        <h2 class="font-medium">Sign out</h2>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">End your session on this device.</p>
      </div>
      <form method="POST" action="/api/logout" class="self-end sm:self-auto">
        <button type="submit" class="btn-secondary">Log out</button>
      </form>
    </section>

    <section class="rounded-md border border-red-200 bg-white p-4 dark:border-red-900 dark:bg-neutral-900">
      <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">Danger zone</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Deleting your account removes your email, password and avatar. Your name is replaced with a stable tombstone so
        shared expenses other members still depend on stay traceable. This cannot be undone.
      </p>
      <form method="POST" action="/api/me-delete" class="flex justify-end">
        <button type="button" data-confirm-open="confirm-delete-account" class="btn-danger">Delete account</button>
      </form>
      <ConfirmDialog
        id="confirm-delete-account"
        title="Delete your account?"
        message="Expenses you paid for stay visible under a tombstone so other members can still trace shared ledgers. This cannot be undone."
        confirmLabel="Delete account"
      />
    </section>
  </div>

  <script>
    import "@/scripts/avatar-pixelate.ts";
    import "@/scripts/confirm-dialog.ts";
  </script>
</Base>
