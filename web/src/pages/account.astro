---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
const PREVIEW_SIZE = 64;

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const err = Astro.url.searchParams.get("error");
const ok = Astro.url.searchParams.get("ok");

const errorMessages: Record<string, string> = {
  rename: "Could not update your display name.",
  password: "Could not change your password. Check your old password and try again.",
  avatar: "Could not save that avatar. It must be a valid image the browser can read.",
  prefs: "Could not update your preferences.",
};
const okMessages: Record<string, string> = {
  rename: "Display name updated.",
  password: "Password changed.",
  avatar: "Avatar updated.",
  avatar_cleared: "Avatar removed.",
  prefs: "Preferences updated.",
};
---

<Base title="Account settings">
  <div class="mx-auto flex max-w-2xl flex-col gap-8">
    <div class="flex items-center gap-4">
      <Avatar
        userId={user.id}
        displayName={user.display_name}
        hasAvatar={user.has_avatar}
        avatarUpdatedAt={user.avatar_updated_at}
        size={56}
      />
      <div>
        <h1 class="text-2xl font-semibold">{user.display_name}</h1>
        <p class="text-sm text-neutral-500">{user.email}</p>
      </div>
    </div>

    {err && errorMessages[err] && (
      <p class="rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200">
        {errorMessages[err]}
      </p>
    )}
    {ok && okMessages[ok] && (
      <p class="rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200">
        {okMessages[ok]}
      </p>
    )}

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Display name</h2>
      <form method="POST" action="/api/me-rename" class="flex flex-col gap-3">
        <input
          name="display_name"
          required
          minlength="1"
          maxlength="80"
          value={user.display_name}
          class="rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm dark:border-neutral-700 dark:bg-neutral-950"
        />
        <div class="flex justify-end">
          <button type="submit" class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300">
            Save name
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Avatar</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Pick any image. We'll pixelate it in your browser to a fun 8×8 mosaic and upload only that 64-pixel tile.
      </p>

      <form
        method="POST"
        action="/api/me-avatar"
        class="flex flex-col gap-3"
        data-avatar-form
      >
        <div class="flex items-center gap-4">
          <div
            class="shrink-0 overflow-hidden rounded border border-neutral-300 dark:border-neutral-700"
            style={`width:${PREVIEW_SIZE}px;height:${PREVIEW_SIZE}px`}
            data-avatar-preview-slot
          >
            {user.has_avatar ? (
              <img
                src={`/api/user-avatar?id=${user.id}&v=${encodeURIComponent(user.avatar_updated_at ?? "")}`}
                alt="Avatar preview"
                width={PREVIEW_SIZE}
                height={PREVIEW_SIZE}
                style={`width:${PREVIEW_SIZE}px;height:${PREVIEW_SIZE}px;display:block`}
              />
            ) : (
              <Avatar
                userId={user.id}
                displayName={user.display_name}
                hasAvatar={false}
                size={PREVIEW_SIZE}
                class="!rounded-none"
              />
            )}
          </div>
          <input
            type="file"
            accept="image/*"
            data-avatar-file
            class="block w-full text-sm file:mr-3 file:rounded-md file:border-0 file:bg-neutral-900 file:px-3 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-neutral-700 dark:file:bg-neutral-100 dark:file:text-neutral-900 dark:hover:file:bg-neutral-300"
          />
        </div>
        <input type="hidden" name="png_base64" data-avatar-b64 />
        <div class="flex justify-end gap-2">
          {user.has_avatar && (
            <button
              type="submit"
              form="avatar-clear-form"
              class="rounded-md border border-neutral-300 px-4 py-2 text-sm font-medium hover:bg-neutral-50 dark:border-neutral-700 dark:hover:bg-neutral-800"
            >
              Remove avatar
            </button>
          )}
          <button
            type="submit"
            data-avatar-submit
            class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 disabled:cursor-not-allowed disabled:opacity-50 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300"
          >
            Save avatar
          </button>
        </div>
      </form>

      {user.has_avatar && (
        <form id="avatar-clear-form" method="POST" action="/api/me-avatar-clear" class="hidden" />
      )}
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Change password</h2>
      <form method="POST" action="/api/me-password" class="flex flex-col gap-3">
        <label class="flex flex-col gap-1 text-sm">
          <span>Current password</span>
          <input
            type="password"
            name="old_password"
            required
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
          />
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>New password</span>
          <input
            type="password"
            name="new_password"
            required
            minlength="10"
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
          />
        </label>
        <div class="flex justify-end">
          <button type="submit" class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300">
            Change password
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Preferences</h2>
      <form method="POST" action="/api/me-preferences" class="flex flex-col gap-3">
        <label class="flex flex-col gap-1 text-sm">
          <span>Week starts on</span>
          <select
            name="week_start"
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
          >
            <option value="1" selected={user.week_start === 1}>Monday</option>
            <option value="0" selected={user.week_start === 0}>Sunday</option>
          </select>
          <span class="text-xs text-neutral-500">Used by the calendar in date pickers across the app.</span>
        </label>
        <div class="flex justify-end">
          <button type="submit" class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300">
            Save preferences
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-md border border-red-200 bg-white p-4 dark:border-red-900 dark:bg-neutral-900">
      <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">Danger zone</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Deleting your account removes your email, password and avatar. Your name is replaced with a stable tombstone so
        shared expenses other members still depend on stay traceable. This cannot be undone.
      </p>
      <form
        method="POST"
        action="/api/me-delete"
        onsubmit="return confirm('Permanently delete your account? Expenses you paid for stay visible under a tombstone. This cannot be undone.');"
      >
        <button type="submit" class="rounded-md border border-red-600 bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">
          Delete account
        </button>
      </form>
    </section>
  </div>

  <script>
    import "@/scripts/avatar-pixelate.ts";
  </script>
</Base>
