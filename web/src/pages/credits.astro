---
import Base from "@/layouts/Base.astro";
import credits from "@/lib/credits.json";

const { project, fontAwesome, inter, backend, frontend } = credits;
---

<Base title="Credits">
  <div class="mx-auto max-w-3xl">
    <h1 class="mb-2 text-2xl font-semibold">Credits</h1>
    <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
      DoTheSplit is built on open-source software. Thanks to all the maintainers
      below.
    </p>

    <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-2 text-lg font-semibold">{project.name}</h2>
      <p class="text-sm text-neutral-700 dark:text-neutral-300">
        {project.copyright}. Released under the
        <a href={`${project.url}/blob/main/LICENSE`} class="underline" rel="noopener noreferrer" target="_blank">{project.license} license</a>.
      </p>
    </section>

    <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-2 text-lg font-semibold">Font Awesome Free Icons</h2>
      <p class="text-sm text-neutral-700 dark:text-neutral-300">
        Icons by
        <a href={fontAwesome.creatorUrl} class="underline" rel="noopener noreferrer" target="_blank">{fontAwesome.creator}</a>,
        licensed under
        <a href={fontAwesome.licenseUrl} class="underline" rel="noopener noreferrer" target="_blank">{fontAwesome.license}</a>
        (<a href={fontAwesome.licensePageUrl} class="underline" rel="noopener noreferrer" target="_blank">license page</a>).
        {fontAwesome.modificationStatement}
      </p>
    </section>

    <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-2 text-lg font-semibold">Inter Font</h2>
      <p class="text-sm text-neutral-700 dark:text-neutral-300">
        Body type by
        <a href={inter.creatorUrl} class="underline" rel="noopener noreferrer" target="_blank">{inter.creator}</a>,
        licensed under the
        <a href={inter.licenseUrl} class="underline" rel="noopener noreferrer" target="_blank">{inter.license}</a>.
        Self-hosted from <code class="font-mono">{inter.licensePath}</code>.
        {inter.modificationStatement}
      </p>
    </section>

    <section class="mb-8">
      <h2 class="mb-2 text-lg font-semibold">Backend dependencies</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Direct Go modules from <code class="font-mono">api/go.mod</code>.
      </p>
      <div class="overflow-x-auto rounded-md border border-neutral-200 dark:border-neutral-800">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50 text-left dark:bg-neutral-900">
            <tr>
              <th class="px-3 py-2 font-medium">Module</th>
              <th class="px-3 py-2 font-medium">Version</th>
              <th class="px-3 py-2 font-medium">License</th>
            </tr>
          </thead>
          <tbody>
            {backend.map((d) => (
              <tr class="border-t border-neutral-200 dark:border-neutral-800">
                <td class="px-3 py-2">
                  <a href={d.url} class="underline" rel="noopener noreferrer" target="_blank">{d.name}</a>
                </td>
                <td class="px-3 py-2 font-mono text-xs">{d.version}</td>
                <td class="px-3 py-2">{d.license}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-2 text-lg font-semibold">Frontend dependencies</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Direct npm packages from <code class="font-mono">web/package.json</code>.
      </p>
      <div class="overflow-x-auto rounded-md border border-neutral-200 dark:border-neutral-800">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50 text-left dark:bg-neutral-900">
            <tr>
              <th class="px-3 py-2 font-medium">Package</th>
              <th class="px-3 py-2 font-medium">Version</th>
              <th class="px-3 py-2 font-medium">License</th>
            </tr>
          </thead>
          <tbody>
            {frontend.map((d) => (
              <tr class="border-t border-neutral-200 dark:border-neutral-800">
                <td class="px-3 py-2">
                  <a href={d.url} class="underline" rel="noopener noreferrer" target="_blank">{d.name}</a>
                </td>
                <td class="px-3 py-2 font-mono text-xs">{d.version}</td>
                <td class="px-3 py-2">{d.license}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8 text-sm text-neutral-600 dark:text-neutral-400">
      <p>
        Full transitive attribution (every direct + indirect dependency, with
        license SPDX and source link) lives in
        <a href={`${project.url}/blob/main/THIRD_PARTY_LICENSES.md`} class="underline" rel="noopener noreferrer" target="_blank">THIRD_PARTY_LICENSES.md</a>.
      </p>
      <p class="mt-2">
        CycloneDX SBOMs (<code class="font-mono">api</code>, <code class="font-mono">worker</code>, <code class="font-mono">web</code>)
        are published as artifacts on each
        <a href={`${project.url}/releases`} class="underline" rel="noopener noreferrer" target="_blank">GitHub Release</a>.
      </p>
    </section>
  </div>
</Base>
