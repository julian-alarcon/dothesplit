---
import Base from "@/layouts/Base.astro";
import FaIcon from "@/components/FaIcon.astro";
import { apiFor } from "@/lib/api/client";

const user = Astro.locals.user;
if (!user || !user.is_admin) return Astro.redirect("/groups");

const cookie = Astro.locals.cookie ?? "";
const api = apiFor(cookie);

// The page response contains the cleartext SMTP password in the input's
// `value=""` attribute. `Cache-Control: no-store` keeps that out of any
// browser/proxy cache so a back-button or shared cache can't surface it.
Astro.response.headers.set("Cache-Control", "no-store");

const { data, response } = await api.GET("/v1/admin/smtp");
const cfg = data ?? null;
const notConfigured = response.status === 404;

const saved = Astro.url.searchParams.get("saved");

// Pre-load the stored cleartext password so "what's in the field is what's
// saved" - empty field on save means wipe, unchanged value means keep. The
// fetch is audit-logged on the backend (`admin_view_smtp_password`). Skip
// the fetch right after a save: the page is already redirected here from
// /api/admin/smtp, the password didn't change between then and now, and we
// don't want a fresh audit row for every save.
let storedPassword = "";
if (cfg?.password_set && saved !== "1") {
  const pw = await api.GET("/v1/admin/smtp/password");
  if (pw.data?.password) storedPassword = pw.data.password;
}
const err = Astro.url.searchParams.get("error");
const test = Astro.url.searchParams.get("test");
const send = Astro.url.searchParams.get("send");

const testMessages: Record<string, { ok: boolean; msg: string }> = {
  ok: { ok: true, msg: "SMTP test connection succeeded." },
  dial_timeout: { ok: false, msg: "Could not connect (dial timeout)." },
  tls_handshake_failed: { ok: false, msg: "TLS handshake failed." },
  starttls_failed: { ok: false, msg: "STARTTLS upgrade failed." },
  smtp_handshake_failed: { ok: false, msg: "SMTP handshake failed." },
  auth_failed: { ok: false, msg: "Authentication failed." },
  password_decrypt_failed: { ok: false, msg: "Stored password could not be decrypted." },
  noop_failed: { ok: false, msg: "NOOP command failed." },
  not_configured: { ok: false, msg: "SMTP is not configured yet." },
  error: { ok: false, msg: "SMTP test errored." },
};

const sendMessages: Record<string, { ok: boolean; msg: string }> = {
  ok: { ok: true, msg: "Test email sent. Check your inbox (and spam folder)." },
  fail: { ok: false, msg: "Test email failed to send. Double-check host, port, TLS mode, and credentials." },
  not_configured: { ok: false, msg: "SMTP is not configured yet." },
  error: { ok: false, msg: "Test email errored." },
};
---

<Base title="Admin · SMTP" back={{ href: "/admin", label: "Admin" }}>
  <h1 class="text-2xl font-semibold mb-1">SMTP configuration</h1>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-4">
    Outbound email settings. The password is encrypted at rest with the same key used for emails. The cleartext is never returned by the API.
  </p>

  {saved && <p class="rounded bg-green-50 px-3 py-2 text-sm text-green-800 mb-4 dark:bg-green-950 dark:text-green-200">Saved.</p>}
  {err && <p class="rounded bg-red-50 px-3 py-2 text-sm text-red-800 mb-4 dark:bg-red-950 dark:text-red-200">Could not save SMTP configuration.</p>}
  {test && testMessages[test] && (
    <p class:list={["rounded px-3 py-2 text-sm mb-4", testMessages[test].ok ? "bg-green-50 text-green-800 dark:bg-green-950 dark:text-green-200" : "bg-red-50 text-red-800 dark:bg-red-950 dark:text-red-200"]}>
      {testMessages[test].msg}
    </p>
  )}
  {send && sendMessages[send] && (
    <p class:list={["rounded px-3 py-2 text-sm mb-4", sendMessages[send].ok ? "bg-green-50 text-green-800 dark:bg-green-950 dark:text-green-200" : "bg-red-50 text-red-800 dark:bg-red-950 dark:text-red-200"]}>
      {sendMessages[send].msg}
    </p>
  )}

  {notConfigured && <p class="rounded bg-neutral-100 px-3 py-2 text-sm text-neutral-700 mb-4 dark:bg-neutral-800 dark:text-neutral-300">SMTP is not configured yet.</p>}

  <form method="POST" action="/api/admin/smtp" class="grid gap-3">
    <label class="field">
      <input name="host" required value={cfg?.host ?? ""} class="field-input" placeholder=" " />
      <span class="field-label" data-required>Host (e.g. smtp.example.com)</span>
    </label>
    <p class="field-error">Required</p>

    <label class="field">
      <input name="port" type="number" min="1" max="65535" required value={cfg?.port ?? 587} class="field-input" placeholder=" " />
      <span class="field-label" data-required>Port</span>
    </label>
    <p class="field-error">Required (1–65535)</p>

    <label class="field-select-row">
      <span class="text-sm">TLS mode</span>
      <select name="tls_mode" class="field-select" data-tls-mode>
        <option value="starttls" selected={cfg?.tls_mode === "starttls" || !cfg}>STARTTLS</option>
        <option value="tls" selected={cfg?.tls_mode === "tls"}>Implicit TLS</option>
        <option value="none" selected={cfg?.tls_mode === "none"}>None (plaintext)</option>
      </select>
    </label>
    <p
      data-tls-warning
      class="rounded bg-amber-50 px-3 py-2 text-sm text-amber-900 dark:bg-amber-950 dark:text-amber-200"
      hidden={cfg?.tls_mode !== "none"}
    >
      Warning: TLS is disabled. The username, password, and every email body
      will travel in plain text. Not recommended outside trusted local
      networks.
    </p>

    <label class="field">
      <input name="username" value={cfg?.username ?? ""} class="field-input" placeholder=" " />
      <span class="field-label">Username (optional)</span>
    </label>

    <label class="field">
      <input name="from_address" type="email" required value={cfg?.from_address ?? ""} class="field-input" placeholder=" " />
      <span class="field-label" data-required>From address</span>
    </label>
    <p class="field-error">Required</p>

    <label class="field">
      <input
        name="smtp_password"
        type="password"
        autocomplete="new-password"
        class="field-input pr-10"
        value={storedPassword}
        placeholder=" "
        data-pwd-input
      />
      <span class="field-label">SMTP password</span>
      <button
        type="button"
        class="absolute right-2 top-1/2 -translate-y-1/2 grid place-items-center rounded p-1 text-neutral-500 hover:text-neutral-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:hover:text-neutral-100 dark:focus-visible:ring-neutral-500"
        aria-label="Show password"
        aria-pressed="false"
        data-pwd-toggle
      >
        <FaIcon name="eye" />
        <FaIcon name="eye-slash" class="hidden" />
      </button>
    </label>

    <div class="flex flex-wrap justify-end gap-2">
      <button type="submit" form="smtp-send-test-form" class="btn-secondary" disabled={notConfigured}>Send test email</button>
      <button type="submit" class="btn-primary">Save and test connection</button>
    </div>
  </form>

  <form id="smtp-send-test-form" method="POST" action="/api/admin/smtp-send-test" class="hidden"></form>

  <script>
    // Show/hide the plaintext-TLS warning as the dropdown changes. The
    // initial state is rendered server-side via `hidden={cfg?.tls_mode !== "none"}`,
    // this script just keeps it in sync without a round-trip.
    const sel = document.querySelector<HTMLSelectElement>("[data-tls-mode]");
    const warn = document.querySelector<HTMLElement>("[data-tls-warning]");
    if (sel && warn) {
      const sync = () => {
        warn.hidden = sel.value !== "none";
      };
      sel.addEventListener("change", sync);
      sync();
    }

    // Password peek toggle. Swaps the input type and the icon (eye / eye-slash)
    // so admins can verify what's there without dropping into DevTools. The
    // current value is the source of truth: empty means wipe on save.
    const pwdInput = document.querySelector<HTMLInputElement>("[data-pwd-input]");
    const pwdToggle = document.querySelector<HTMLButtonElement>("[data-pwd-toggle]");
    if (pwdInput && pwdToggle) {
      const [eye, eyeSlash] = pwdToggle.querySelectorAll<SVGElement>("svg");
      pwdToggle.addEventListener("click", () => {
        const showing = pwdInput.type === "text";
        pwdInput.type = showing ? "password" : "text";
        pwdToggle.setAttribute("aria-pressed", String(!showing));
        pwdToggle.setAttribute("aria-label", showing ? "Show password" : "Hide password");
        eye?.classList.toggle("hidden", !showing);
        eyeSlash?.classList.toggle("hidden", showing);
      });
    }
  </script>
</Base>
