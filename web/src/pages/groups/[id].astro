---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import SplitEditor from "@/components/SplitEditor.astro";
import DatePicker from "@/components/DatePicker.astro";
import FaIcon from "@/components/FaIcon.astro";
import CategoryIcon from "@/components/CategoryIcon.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, balancesRes, categoriesRes, recurringRes, activityRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/groups/{id}/balances", { params: { path: { id } } }),
  api.GET("/v1/categories"),
  api.GET("/v1/groups/{id}/recurring-expenses", { params: { path: { id } } }),
  api.GET("/v1/groups/{id}/activity", { params: { path: { id } } }),
]);

const group = groupsRes.data?.find((g) => g.id === id);
if (!group) {
  return Astro.redirect("/groups");
}
const net = balancesRes.data?.net ?? [];
const simplified = balancesRes.data?.simplified ?? [];
const recurringTemplates = recurringRes.data ?? [];
const categories = categoriesRes.data ?? [];
const activity = activityRes.data?.items ?? [];
const nextCursor = activityRes.data?.next_cursor ?? "";

// Unified activity feed: paginated server-side via /v1/groups/{id}/activity
// (50 items by default, with `next_cursor` driving the Load-more island).
// Cadence (when an expense matches a recurring template) is now resolved
// server-side and lives on each ActivityItem.
const cadenceLabels: Record<string, string> = {
  daily: "daily",
  weekly: "weekly",
  biweekly: "every 2 weeks",
  monthly: "monthly",
  yearly: "yearly",
};
const categoryByID = new Map(categories.map((c) => [c.id, c]));
const otherCategory = categories.find((c) => c.slug === "other");
const defaultCategory = otherCategory ?? categories[0];
const defaultCategoryID = defaultCategory?.id ?? "";
const defaultSlug = defaultCategory?.slug ?? "other";
const defaultGroupLabel = defaultCategory?.group_label ?? "No category";
const currency = group.default_currency;

const nameByUserID = new Map<string, string>();
const memberByID = new Map(group.members.map((m) => [m.user_id, m]));
for (const m of group.members) nameByUserID.set(m.user_id, m.display_name);

const moneyFmt = new Intl.NumberFormat(undefined, {
  style: "currency",
  currency,
  currencyDisplay: "narrowSymbol",
});
const format = (cents: number) => moneyFmt.format(cents / 100);

const dateFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium" });

// Default the create form to today (UTC) so the rendered <input type="date">
// matches whatever the user sees in the expense list.
const todayISO = new Date().toISOString().slice(0, 10);

// Surfaced when redirected here from /api/groups with one or more failed invites
// (unregistered emails). Parse defensively so a tampered URL can't break render.
const inviteFailedRaw = Astro.url.searchParams.get("invite_failed");
const inviteFailedCount = inviteFailedRaw && /^\d+$/.test(inviteFailedRaw) ? Number(inviteFailedRaw) : 0;
---

<Base title={group.name} wide back={{ href: "/groups", label: "Groups" }}>
  <div class="mb-2 flex items-baseline justify-between gap-3">
    <h1 class="min-w-0 flex-1 truncate text-2xl font-semibold">{group.name}</h1>
    <div class="flex shrink-0 items-center gap-2">
      <a
        href={`/groups/${id}/recurring`}
        aria-label={`Recurring expenses (${recurringTemplates.length})`}
        title="Recurring expenses"
        class="btn-secondary btn-sm h-9"
      >
        <FaIcon name="arrows-rotate" />
        <span class="hidden sm:inline">Recurring</span>
        {recurringTemplates.length > 0 && (
          <span class="tabular-nums">({recurringTemplates.length})</span>
        )}
      </a>
      <a
        href={`/groups/${id}/settings`}
        aria-label="Group settings"
        title="Group settings"
        class="btn-secondary btn-sm h-9"
      >
        <FaIcon name="gear" />
        <span class="hidden sm:inline">Group settings</span>
      </a>
    </div>
  </div>
  <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
    {group.members.length} member{group.members.length === 1 ? "" : "s"} · default currency {currency}
  </p>

  {inviteFailedCount > 0 && (
    <p
      role="status"
      aria-live="polite"
      class="mb-4 flex flex-wrap items-center justify-between gap-2 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-200"
    >
      <span>
        {inviteFailedCount === 1
          ? "1 invite was skipped — that email isn't a registered user yet."
          : `${inviteFailedCount} invites were skipped — those emails aren't registered users yet.`}
      </span>
      <a href={`/groups/${id}/settings`} class="font-medium underline">Add members</a>
    </p>
  )}

  <div class="grid grid-cols-1 items-start gap-4 lg:grid-cols-[20.5rem_minmax(0,1fr)_20.5rem]">
  <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900 lg:order-1">
    <div class="mb-3 flex items-center justify-between gap-3">
      <h2 class="font-medium">Balances</h2>
      <a href={`/groups/${id}/settle`} class="btn-secondary btn-sm">Settle up</a>
    </div>
    <div class="flex flex-col gap-6">
      <ul class="flex flex-col gap-2 text-sm">
        {net.map((b) => {
          const m = memberByID.get(b.user_id);
          return (
            <li class="flex items-center justify-between gap-2">
              <span class="flex min-w-0 items-center gap-2">
                <Avatar
                  userId={b.user_id}
                  displayName={b.display_name}
                  hasAvatar={m?.has_avatar}
                  avatarUpdatedAt={m?.avatar_updated_at}
                  size={20}
                />
                <span class="truncate">{b.display_name}</span>
              </span>
              <span class={`shrink-0 font-mono ${b.net_cents >= 0 ? "text-emerald-700 dark:text-emerald-400" : "text-red-700 dark:text-red-400"}`}>
                {format(b.net_cents)}
              </span>
            </li>
          );
        })}
      </ul>
      {simplified.length > 0 && (
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-neutral-600 dark:text-neutral-400">Suggested transfers</h3>
          <ul class="flex flex-col gap-2 text-sm">
            {simplified.map((d) => {
              const from = memberByID.get(d.from_user_id);
              const to = memberByID.get(d.to_user_id);
              return (
                <li class="flex items-center justify-between gap-2">
                  <span class="flex min-w-0 items-center gap-2">
                    <Avatar
                      userId={d.from_user_id}
                      displayName={from?.display_name ?? "?"}
                      hasAvatar={from?.has_avatar}
                      avatarUpdatedAt={from?.avatar_updated_at}
                      size={18}
                    />
                    <span class="truncate">{nameByUserID.get(d.from_user_id)}</span>
                    <span class="text-neutral-600 dark:text-neutral-400">
                      <FaIcon name="arrow-right" size={12} />
                    </span>
                    <Avatar
                      userId={d.to_user_id}
                      displayName={to?.display_name ?? "?"}
                      hasAvatar={to?.has_avatar}
                      avatarUpdatedAt={to?.avatar_updated_at}
                      size={18}
                    />
                    <span class="truncate">{nameByUserID.get(d.to_user_id)}</span>
                  </span>
                  <span class="shrink-0 font-mono">{format(d.amount_cents)}</span>
                </li>
              );
            })}
          </ul>
        </div>
      )}
    </div>
  </section>

  <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900 lg:order-3">
    <h2 class="mb-3 font-medium">Add expense</h2>
    <form method="POST" action={`/api/expenses?id=${id}`} class="flex flex-col gap-4">
      <div class="flex items-end gap-2" data-category-picker>
        <input type="hidden" name="category_id" value={defaultCategoryID} />
        <button
          type="button"
          data-category-open
          aria-label="Choose category"
          title="Choose category"
          class="field-category-trigger"
        >
          <span data-category-icon class="inline-flex items-center justify-center">
            <CategoryIcon slug={defaultSlug} groupLabel={defaultGroupLabel} size={38} />
          </span>
        </button>
        <div class="flex flex-1 flex-col">
          <label class="field">
            <input name="description" required maxlength="200" placeholder=" " class="field-input" />
            <span class="field-label" data-required>What was it?</span>
          </label>
          <p class="field-error">Required</p>
        </div>
        <dialog
          data-category-dialog
          aria-modal="true"
          aria-labelledby="category-dialog-title"
          class="fixed inset-0 m-auto w-[calc(100%-2rem)] max-w-sm rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
        >
          <div class="flex flex-col gap-3 p-5">
            <div class="flex items-center justify-between gap-3">
              <h3 id="category-dialog-title" class="text-lg font-medium">Choose category</h3>
              <button
                type="button"
                data-category-cancel
                aria-label="Close"
                title="Close"
                class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:focus-visible:ring-neutral-500"
              >
                <FaIcon name="xmark" size={14} />
              </button>
            </div>
            <ul class="flex max-h-[60vh] flex-col gap-0.5 overflow-auto">
              {categories.map((c, i) => (
                <>
                  {(i === 0 || categories[i - 1].group_label !== c.group_label) && (
                    <li class="field-category-group" role="presentation">{c.group_label}</li>
                  )}
                  <li>
                    <button
                      type="button"
                      data-category-option
                      data-category-id={c.id}
                      data-slug={c.slug}
                      data-group-label={c.group_label}
                      class="field-category-option"
                    >
                      <CategoryIcon slug={c.slug} groupLabel={c.group_label} size={28} />
                      <span>{c.label}</span>
                    </button>
                  </li>
                </>
              ))}
            </ul>
          </div>
        </dialog>
      </div>
      <div class="flex flex-col gap-4">
        <div>
          <label class="field">
            <input type="hidden" name="amount_dollars" />
            <input
              type="text"
              inputmode="decimal"
              data-currency-input
              data-currency-hidden="amount_dollars"
              data-currency={currency}
              required
              placeholder=" "
              class="field-input field-input-currency"
            />
            <span class="field-label" data-required>Amount ({currency})</span>
          </label>
          <p class="field-error">Enter an amount greater than 0</p>
        </div>
        <label class="field-select-row">
          <span>Paid by</span>
          <select name="payer_id" required class="field-select">
            {group.members.map((m) => (
              <option value={m.user_id} selected={m.user_id === Astro.locals.user?.id}>
                {m.display_name}
              </option>
            ))}
          </select>
        </label>
      </div>
      <SplitEditor
        members={group.members}
        currency={currency}
        currentUserId={Astro.locals.user?.id}
        defaultSplit={group.default_split ?? []}
      />
      <div class="flex items-center justify-end gap-2">
        <DatePicker
          name="incurred_at"
          value={todayISO}
          variant="compact"
          ariaLabel="Pick date"
          cadenceName="cadence"
          weekStart={Astro.locals.user?.week_start === 0 ? 0 : 1}
        />
        <button type="submit" class="btn-primary">Add expense</button>
      </div>
    </form>
  </section>

  <section class="lg:order-2">
    <h2 class="mb-3 font-medium">Activity</h2>
    {activity.length === 0 ? (
      <p class="text-sm text-neutral-500">No expenses or settlements yet.</p>
    ) : (
      <ul class="flex flex-col gap-2" data-activity-list>
        {activity.map((item) => {
          if (item.kind === "expense" && item.expense) {
            const e = item.expense;
            const cat = categoryByID.get(e.category_id);
            const cadence = item.cadence;
            return (
              <li>
                <a
                  href={`/groups/${id}/expenses/${e.id}`}
                  class="flex items-center justify-between gap-3 rounded-md border border-neutral-200 bg-white px-4 py-3 hover:bg-neutral-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:bg-neutral-800 dark:focus-visible:ring-neutral-500"
                >
                  <div class="flex min-w-0 items-center gap-3">
                    <span class="shrink-0 inline-flex items-center justify-center" title={cat?.label ?? ""}>
                      <CategoryIcon slug={cat?.slug} groupLabel={cat?.group_label} size={28} />
                    </span>
                    <div class="min-w-0">
                      <div class="flex flex-wrap items-center gap-1.5 font-medium">
                        <span class="truncate">{e.description}</span>
                        {cadence && (
                          <span
                            class="inline-flex items-center gap-1 rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium uppercase tracking-wide text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
                            title={`Repeats ${cadenceLabels[cadence] ?? cadence}`}
                          >
                            <FaIcon name="arrows-rotate" size={11} />
                            {cadenceLabels[cadence] ?? cadence}
                          </span>
                        )}
                      </div>
                      <div class="flex flex-wrap items-center gap-1.5 text-xs text-neutral-600 dark:text-neutral-400">
                        <span>{dateFmt.format(new Date(e.incurred_at))} · paid by</span>
                        <Avatar
                          userId={e.payer_id}
                          displayName={nameByUserID.get(e.payer_id) ?? "?"}
                          hasAvatar={memberByID.get(e.payer_id)?.has_avatar}
                          avatarUpdatedAt={memberByID.get(e.payer_id)?.avatar_updated_at}
                          size={16}
                        />
                        <span class="truncate">{nameByUserID.get(e.payer_id) ?? "?"}</span>
                      </div>
                    </div>
                  </div>
                  <span class="shrink-0 font-mono">
                    {new Intl.NumberFormat(undefined, { style: "currency", currency: e.currency, currencyDisplay: "narrowSymbol" }).format(e.amount_cents / 100)}
                  </span>
                </a>
              </li>
            );
          }
          if (!item.settlement) return null;
          const s = item.settlement;
          const from = memberByID.get(s.from_user_id);
          const to = memberByID.get(s.to_user_id);
          return (
            <li>
              <a
                href={`/groups/${id}/settlements/${s.id}`}
                class="flex items-center justify-between gap-3 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 hover:bg-emerald-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 dark:border-emerald-900 dark:bg-emerald-950/40 dark:hover:bg-emerald-950/60 dark:focus-visible:ring-emerald-700"
              >
                <div class="flex min-w-0 items-center gap-3">
                  <span class="shrink-0 inline-flex h-7 w-7 items-center justify-center rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300" title="Settlement">
                    <FaIcon name="arrow-right" size={14} />
                  </span>
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-1.5 font-medium">
                      <Avatar
                        userId={s.from_user_id}
                        displayName={from?.display_name ?? "?"}
                        hasAvatar={from?.has_avatar}
                        avatarUpdatedAt={from?.avatar_updated_at}
                        size={18}
                      />
                      <span class="truncate">{nameByUserID.get(s.from_user_id) ?? "?"}</span>
                      <span class="text-neutral-600 dark:text-neutral-400">paid</span>
                      <Avatar
                        userId={s.to_user_id}
                        displayName={to?.display_name ?? "?"}
                        hasAvatar={to?.has_avatar}
                        avatarUpdatedAt={to?.avatar_updated_at}
                        size={18}
                      />
                      <span class="truncate">{nameByUserID.get(s.to_user_id) ?? "?"}</span>
                    </div>
                    <div class="flex flex-wrap items-center gap-1.5 text-xs text-neutral-600 dark:text-neutral-400">
                      <span>{dateFmt.format(new Date(s.settled_at))} · settlement</span>
                      {s.note && <span class="truncate">· {s.note}</span>}
                    </div>
                  </div>
                </div>
                <span class="shrink-0 font-mono">
                  {new Intl.NumberFormat(undefined, { style: "currency", currency, currencyDisplay: "narrowSymbol" }).format(s.amount_cents / 100)}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
    {nextCursor && (
      <div class="mt-3 flex justify-center">
        <button
          type="button"
          data-activity-load-more
          data-group-id={id}
          data-cursor={nextCursor}
          class="btn-secondary btn-sm"
        >
          Load more
        </button>
      </div>
    )}
  </section>
  </div>

  <script>
    import "@/scripts/category-picker.ts";
    import "@/scripts/split-editor.ts";
    import "@/scripts/date-picker.ts";
    import "@/scripts/currency-input.ts";
    import "@/scripts/activity-load-more.ts";
  </script>
</Base>
