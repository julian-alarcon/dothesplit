---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import SplitEditor from "@/components/SplitEditor.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, expensesRes, balancesRes, categoriesRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/groups/{id}/expenses", { params: { path: { id } } }),
  api.GET("/v1/groups/{id}/balances", { params: { path: { id } } }),
  api.GET("/v1/categories"),
]);

const group = groupsRes.data?.find((g) => g.id === id);
if (!group) {
  return Astro.redirect("/groups");
}
const expenses = expensesRes.data ?? [];
const net = balancesRes.data?.net ?? [];
const simplified = balancesRes.data?.simplified ?? [];
const categories = categoriesRes.data ?? [];
const categoryByID = new Map(categories.map((c) => [c.id, c]));
const otherCategory = categories.find((c) => c.slug === "other");
const defaultCategoryID = otherCategory?.id ?? categories[0]?.id ?? "";
const defaultEmoji = otherCategory?.emoji ?? "📌";
const currency = group.default_currency;
const isCreator = group.created_by === Astro.locals.user?.id;

const settingsOpen = Astro.url.searchParams.get("settings") === "1";
const showSettingsError = Astro.url.searchParams.get("settings_error") === "1";

const isPair = group.members.length === 2;
const pairMembers = isPair ? group.members : [];
const defaultSplit = group.default_split ?? [];
const hasDefaultSplit = defaultSplit.length === 2;
const dsBPByUser = new Map<string, number>();
for (const e of defaultSplit) dsBPByUser.set(e.user_id, e.basis_points);
const pairPrefill = pairMembers.map((m) => ({
  member: m,
  percent: ((dsBPByUser.get(m.user_id) ?? 5000) / 100).toString(),
}));

const nameByUserID = new Map<string, string>();
const memberByID = new Map(group.members.map((m) => [m.user_id, m]));
for (const m of group.members) nameByUserID.set(m.user_id, m.display_name);

const moneyFmt = new Intl.NumberFormat(undefined, {
  style: "currency",
  currency,
  currencyDisplay: "narrowSymbol",
});
const format = (cents: number) => moneyFmt.format(cents / 100);

const dateFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium" });

const currencyChoices = ["EUR", "USD", "GBP", "CHF", "CAD", "AUD", "JPY", "SEK", "NOK", "DKK"];
---

<Base title={group.name}>
  <div class="mb-2 flex items-center justify-between gap-3">
    <h1 class="text-2xl font-semibold">{group.name}</h1>
    <a
      href={settingsOpen ? `/groups/${id}` : `/groups/${id}?settings=1`}
      class="rounded-md border border-neutral-300 bg-white px-3 py-1.5 text-sm hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800"
    >
      {settingsOpen ? "Close settings" : "Group settings"}
    </a>
  </div>
  <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
    {group.members.length} member{group.members.length === 1 ? "" : "s"} · default currency {currency}
  </p>

  {settingsOpen && (
    <section
      id="settings"
      class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
    >
      <h2 class="mb-4 text-lg font-medium">Group settings</h2>

      {showSettingsError && (
        <p class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200">
          Could not update the group. Check your input and try again.
        </p>
      )}

      <div class="grid gap-6 md:grid-cols-2">
        <div>
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-neutral-500">Rename &amp; currency</h3>
          <form method="POST" action={`/api/group-settings?id=${id}`} class="flex flex-col gap-2">
            <label class="flex flex-col gap-1 text-sm">
              <span>Name</span>
              <input
                name="name"
                required
                minlength="1"
                maxlength="80"
                value={group.name}
                class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
              />
            </label>
            <label class="flex flex-col gap-1 text-sm">
              <span>Default currency</span>
              <select
                name="default_currency"
                class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
              >
                {currencyChoices.map((c) => (
                  <option value={c} selected={c === currency}>{c}</option>
                ))}
              </select>
            </label>
            <button
              type="submit"
              class="mt-1 self-start rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300"
            >
              Save
            </button>
          </form>
        </div>

        <div>
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-neutral-500">Members</h3>
          <ul class="mb-3 flex flex-col gap-1 text-sm">
            {group.members.map((m) => (
              <li class="flex items-center justify-between">
                <span class="flex items-center gap-2">
                  <Avatar
                    userId={m.user_id}
                    displayName={m.display_name}
                    hasAvatar={m.has_avatar}
                    avatarUpdatedAt={m.avatar_updated_at}
                    size={20}
                  />
                  <span>{m.display_name}</span>
                </span>
                {m.user_id === group.created_by && (
                  <span class="text-xs uppercase tracking-wide text-neutral-500">creator</span>
                )}
              </li>
            ))}
          </ul>
          {isPair && hasDefaultSplit && (
            <p class="mb-2 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-xs text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-200">
              Adding a 3rd member will clear the pinned default split. New expenses will fall back to an equal split until you set a new default.
            </p>
          )}
          <form
            method="POST"
            action={`/api/group-members?id=${id}`}
            class="flex gap-2"
          >
            <input
              type="email"
              name="email"
              placeholder="new.member@example.com"
              required
              class="flex-1 rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm dark:border-neutral-700 dark:bg-neutral-950"
            />
            <button type="submit" class="rounded-md bg-neutral-900 px-3 py-2 text-sm font-medium text-white dark:bg-neutral-100 dark:text-neutral-900">
              Add
            </button>
          </form>
          <p class="mt-1 text-xs text-neutral-500">The invitee must already be registered.</p>
        </div>
      </div>

      <div class="mt-8 border-t border-neutral-200 pt-4 dark:border-neutral-800">
        <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-neutral-500">
          Default split
        </h3>
        <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
          {!isPair
            ? "Only available for 2-member groups. New expenses default to an equal split."
            : hasDefaultSplit
              ? "New expenses prefill with this percentage split. The split editor still lets you change it per-expense."
              : "Pin a percentage split (e.g. 60/40) to prefill new expenses. Cleared automatically if a 3rd member joins."}
        </p>
        <fieldset disabled={!isPair} class="contents">
          <form
            method="POST"
            action={`/api/group-default-split?id=${id}`}
            class="flex flex-col gap-2"
          >
            <input type="hidden" name="action" value="set" />
            {(isPair ? pairPrefill : group.members.slice(0, 2).map((m) => ({ member: m, percent: "50" }))).map((p, i) => (
              <div class="flex items-center gap-2 text-sm">
                <span class="flex-1">{p.member.display_name}</span>
                <input type="hidden" name={`member_id_${i + 1}`} value={p.member.user_id} />
                <input
                  type="number"
                  name={`percent_${i + 1}`}
                  step="0.01"
                  min="0"
                  max="100"
                  required
                  value={p.percent}
                  disabled={!isPair}
                  class="w-20 rounded-md border border-neutral-300 bg-white px-2 py-1 text-right text-sm tabular-nums disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-950"
                />
                <span class="text-neutral-500">%</span>
              </div>
            ))}
            <p class="text-xs text-neutral-500">Must sum to 100.</p>
            <div class="flex gap-2">
              <button
                type="submit"
                disabled={!isPair}
                class="rounded-md bg-neutral-900 px-3 py-1.5 text-sm font-medium text-white disabled:cursor-not-allowed disabled:opacity-50 dark:bg-neutral-100 dark:text-neutral-900"
              >
                {hasDefaultSplit ? "Update default" : "Pin default"}
              </button>
            </div>
          </form>
          {hasDefaultSplit && isPair && (
            <form
              method="POST"
              action={`/api/group-default-split?id=${id}`}
              class="mt-2"
            >
              <input type="hidden" name="action" value="clear" />
              <button
                type="submit"
                class="rounded-md border border-neutral-300 bg-white px-3 py-1.5 text-sm hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800"
              >
                Clear default
              </button>
            </form>
          )}
        </fieldset>
      </div>

      {isCreator && (
        <div class="mt-8 border-t border-red-200 pt-4 dark:border-red-900">
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">
            Danger zone
          </h3>
          <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
            Deleting the group removes all its expenses, settlements and recurring templates. This cannot be undone.
          </p>
          <form
            method="POST"
            action={`/api/group-delete?id=${id}`}
            onsubmit="return confirm('Delete this group and all its data? This cannot be undone.');"
          >
            <button
              type="submit"
              class="rounded-md border border-red-600 bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700"
            >
              Delete group
            </button>
          </form>
        </div>
      )}
    </section>
  )}

  <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <div class="mb-3 flex items-center justify-between gap-3">
      <h2 class="font-medium">Balances</h2>
      <a
        href={`/groups/${id}/settle`}
        class="rounded-md border border-neutral-300 bg-white px-3 py-1.5 text-sm hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:bg-neutral-800"
      >
        Settle up
      </a>
    </div>
    <ul class="flex flex-col gap-1 text-sm">
      {net.map((b) => {
        const m = memberByID.get(b.user_id);
        return (
          <li class="flex items-center justify-between gap-2">
            <span class="flex items-center gap-2">
              <Avatar
                userId={b.user_id}
                displayName={b.display_name}
                hasAvatar={m?.has_avatar}
                avatarUpdatedAt={m?.avatar_updated_at}
                size={20}
              />
              <span>{b.display_name}</span>
            </span>
            <span class={b.net_cents >= 0 ? "text-emerald-600" : "text-red-600"}>
              {format(b.net_cents)}
            </span>
          </li>
        );
      })}
    </ul>
    {simplified.length > 0 && (
      <>
        <h3 class="mt-4 mb-2 text-xs font-semibold uppercase tracking-wide text-neutral-500">Suggested transfers</h3>
        <ul class="flex flex-col gap-1 text-sm">
          {simplified.map((d) => {
            const from = memberByID.get(d.from_user_id);
            const to = memberByID.get(d.to_user_id);
            return (
              <li class="flex items-center justify-between gap-2">
                <span class="flex items-center gap-2">
                  <Avatar
                    userId={d.from_user_id}
                    displayName={from?.display_name ?? "?"}
                    hasAvatar={from?.has_avatar}
                    avatarUpdatedAt={from?.avatar_updated_at}
                    size={18}
                  />
                  <span>{nameByUserID.get(d.from_user_id)}</span>
                  <span class="text-neutral-500">→</span>
                  <Avatar
                    userId={d.to_user_id}
                    displayName={to?.display_name ?? "?"}
                    hasAvatar={to?.has_avatar}
                    avatarUpdatedAt={to?.avatar_updated_at}
                    size={18}
                  />
                  <span>{nameByUserID.get(d.to_user_id)}</span>
                </span>
                <span>{format(d.amount_cents)}</span>
              </li>
            );
          })}
        </ul>
      </>
    )}
  </section>

  <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Add expense</h2>
    <form method="POST" action={`/api/expenses?id=${id}`} class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm">
        <span>Description</span>
        <div class="flex items-stretch gap-2">
          <details class="group relative" data-category-picker>
            <summary
              class="flex h-full cursor-pointer list-none items-center justify-center rounded-md border border-neutral-300 bg-white px-3 text-xl leading-none hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-950 dark:hover:bg-neutral-900"
              aria-label="Choose category"
              title="Choose category"
              data-category-emoji
            >
              {defaultEmoji}
            </summary>
            <div class="absolute left-0 top-full z-10 mt-1 w-56 rounded-md border border-neutral-300 bg-white p-2 shadow-lg dark:border-neutral-700 dark:bg-neutral-950">
              <ul class="flex max-h-64 flex-col gap-0.5 overflow-auto">
                {categories.map((c) => (
                  <li>
                    <label class="flex cursor-pointer items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-900">
                      <input
                        type="radio"
                        name="category_id"
                        value={c.id}
                        data-category-option
                        data-emoji={c.emoji}
                        checked={c.id === defaultCategoryID}
                        class="accent-neutral-900 dark:accent-neutral-100"
                      />
                      <span class="text-lg leading-none">{c.emoji}</span>
                      <span>{c.label}</span>
                    </label>
                  </li>
                ))}
              </ul>
            </div>
          </details>
          <input name="description" required maxlength="200" placeholder="What was it?" class="flex-1 rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
        </div>
      </label>
      <label class="flex flex-col gap-1 text-sm">
        <span>Amount ({currency})</span>
        <input type="number" name="amount_dollars" step="0.01" min="0.01" required class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
      </label>
      <label class="flex flex-col gap-1 text-sm">
        <span>Payer</span>
        <select name="payer_id" required class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
          {group.members.map((m) => (
            <option value={m.user_id} selected={m.user_id === Astro.locals.user?.id}>
              {m.display_name}
            </option>
          ))}
        </select>
      </label>
      <div class="flex flex-col gap-1 text-sm">
        <span>Split</span>
        <SplitEditor
          members={group.members}
          currency={currency}
          currentUserId={Astro.locals.user?.id}
          defaultSplit={group.default_split ?? []}
        />
      </div>
      <div class="flex justify-end">
        <button type="submit" class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white dark:bg-neutral-100 dark:text-neutral-900">
          Add expense
        </button>
      </div>
    </form>
  </section>

  <section>
    <h2 class="mb-3 font-medium">Expenses</h2>
    {expenses.length === 0 ? (
      <p class="text-sm text-neutral-500">No expenses yet.</p>
    ) : (
      <ul class="flex flex-col gap-2">
        {expenses.map((e) => {
          const cat = categoryByID.get(e.category_id);
          return (
            <li>
              <a
                href={`/groups/${id}/expenses/${e.id}`}
                class="flex items-center justify-between rounded-md border border-neutral-200 bg-white px-4 py-3 hover:bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:bg-neutral-800"
              >
                <div class="flex items-center gap-3">
                  <span class="text-xl leading-none" title={cat?.label ?? ""}>{cat?.emoji ?? "📌"}</span>
                  <div>
                    <div class="font-medium">{e.description}</div>
                    <div class="flex items-center gap-1.5 text-xs text-neutral-500">
                      <span>{dateFmt.format(new Date(e.incurred_at))} · paid by</span>
                      <Avatar
                        userId={e.payer_id}
                        displayName={nameByUserID.get(e.payer_id) ?? "?"}
                        hasAvatar={memberByID.get(e.payer_id)?.has_avatar}
                        avatarUpdatedAt={memberByID.get(e.payer_id)?.avatar_updated_at}
                        size={16}
                      />
                      <span>{nameByUserID.get(e.payer_id) ?? "?"}</span>
                    </div>
                  </div>
                </div>
                <span class="font-mono">
                  {new Intl.NumberFormat(undefined, { style: "currency", currency: e.currency, currencyDisplay: "narrowSymbol" }).format(e.amount_cents / 100)}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>

  <script>
    import "@/scripts/category-picker.ts";
    import "@/scripts/split-editor.ts";
  </script>
</Base>
