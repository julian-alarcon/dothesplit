---
import Base from "@/layouts/Base.astro";
import { COMMON_CURRENCIES, otherCurrencies, currencyLabel } from "@/lib/currencies";

const locale = Astro.locals.locale;
const others = otherCurrencies();
---

<Base title="New group">
  <div class="mx-auto max-w-md">
    <h1 class="mb-6 text-2xl font-semibold">New group</h1>
    <form method="POST" action="/api/groups" class="flex flex-col gap-3 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <label class="field">
        <input name="name" required maxlength="80" placeholder=" " class="field-input" />
        <span class="field-label" data-required>Group name</span>
      </label>
      <p class="field-error">Required</p>
      <label class="field-select-row">
        <span>Default currency</span>
        <select name="default_currency" class="field-select">
          <optgroup label="Common">
            {COMMON_CURRENCIES.map((c) => (
              <option value={c} selected={c === "EUR"}>{currencyLabel(c, locale)}</option>
            ))}
          </optgroup>
          <optgroup label="All currencies">
            {others.map((c) => (
              <option value={c}>{currencyLabel(c, locale)}</option>
            ))}
          </optgroup>
        </select>
      </label>
      <label class="field">
        <textarea
          name="member_emails"
          rows="4"
          placeholder=" "
          class="field-input"
        ></textarea>
        <span class="field-label">Add members (optional)</span>
      </label>
      <p class="-mt-1 text-xs text-neutral-600 dark:text-neutral-400">
        One email per line. Only registered users can be added - others are skipped and you can retry from group settings.
      </p>
      <button type="submit" class="btn-primary mt-2 self-end">Create group</button>
    </form>
  </div>
</Base>
