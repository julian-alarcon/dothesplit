---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import SplitEditor from "@/components/SplitEditor.astro";
import DatePicker from "@/components/DatePicker.astro";
import { apiFor } from "@/lib/api/client";

const { id, eid } = Astro.params as { id: string; eid: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, expenseRes, revisionsRes, categoriesRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/expenses/{id}", { params: { path: { id: eid } } }),
  api.GET("/v1/expenses/{id}/revisions", { params: { path: { id: eid } } }),
  api.GET("/v1/categories"),
]);

const group = groupsRes.data?.find((g) => g.id === id);
const expense = expenseRes.data;
if (!group || !expense) {
  return Astro.redirect(`/groups/${id}`);
}
const categories = categoriesRes.data ?? [];
const revisions = revisionsRes.data ?? [];
const categoryByID = new Map(categories.map((c) => [c.id, c]));

const currency = expense.currency;
const moneyFmt = new Intl.NumberFormat(undefined, {
  style: "currency",
  currency,
  currencyDisplay: "narrowSymbol",
});
const formatMoney = (cents: number) => moneyFmt.format(cents / 100);
const formatCents = (cents: number) => (cents / 100).toFixed(2);
const dateTimeFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium", timeStyle: "short" });
const dateFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium" });

// "YYYY-MM-DD" form for <input type="date"> using the UTC slice. The create
// flow anchors at noon UTC, so this preserves the user's intended day.
const incurredAtISO = new Date(expense.incurred_at).toISOString().slice(0, 10);
const createdAtDiffers =
  new Date(expense.created_at).toISOString().slice(0, 10) !== incurredAtISO;

const userID = Astro.locals.user?.id;
const isMember = group.members.some((m) => m.user_id === userID);
const canEdit = isMember;
const canDelete = expense.payer_id === userID || group.created_by === userID;

const nameByUserID = new Map<string, string>();
const memberByID = new Map(group.members.map((m) => [m.user_id, m]));
for (const m of group.members) nameByUserID.set(m.user_id, m.display_name);

const currentCategory = categoryByID.get(expense.category_id);

const showError = Astro.url.searchParams.get("error") === "1";

// Turn a revision's raw old/new value into a reader-friendly label.
function renderValue(field: string, value: string): string {
  if (field === "amount_cents") {
    const n = Number(value);
    return Number.isFinite(n) ? formatMoney(n) : value;
  }
  if (field === "category_id") {
    return categoryByID.get(value)?.label ?? value;
  }
  if (field === "payer_id") {
    return nameByUserID.get(value) ?? value;
  }
  if (field === "splits") {
    try {
      const parsed = JSON.parse(value) as { user_id: string; share_cents: number }[];
      if (!Array.isArray(parsed) || parsed.length === 0) return "—";
      return parsed
        .map((s) => `${nameByUserID.get(s.user_id) ?? s.user_id}: ${formatMoney(s.share_cents)}`)
        .join(", ");
    } catch {
      return value;
    }
  }
  if (field === "incurred_at") {
    const d = new Date(value);
    return Number.isNaN(d.getTime()) ? value : dateFmt.format(d);
  }
  return value;
}
const fieldLabel: Record<string, string> = {
  description: "Description",
  amount_cents: "Amount",
  category_id: "Category",
  payer_id: "Payer",
  splits: "Splits",
  incurred_at: "Date",
};
---

<Base title={expense.description}>
  <div class="mb-4 flex items-center gap-2 text-sm">
    <a href={`/groups/${id}`} class="text-neutral-600 hover:underline dark:text-neutral-400">← Back to {group.name}</a>
  </div>

  <div class="mb-6 flex items-center gap-3">
    <span class="text-3xl leading-none">{currentCategory?.emoji ?? "📌"}</span>
    <div>
      <h1 class="text-2xl font-semibold">{expense.description}</h1>
      <p class="flex flex-wrap items-center gap-1.5 text-sm text-neutral-500">
        <span>{dateFmt.format(new Date(expense.incurred_at))} · paid by</span>
        <Avatar
          userId={expense.payer_id}
          displayName={nameByUserID.get(expense.payer_id) ?? "?"}
          hasAvatar={memberByID.get(expense.payer_id)?.has_avatar}
          avatarUpdatedAt={memberByID.get(expense.payer_id)?.avatar_updated_at}
          size={18}
        />
        <span>{nameByUserID.get(expense.payer_id) ?? "?"}</span>
        <span>· {formatMoney(expense.amount_cents)}</span>
      </p>
    </div>
  </div>

  {showError && (
    <p class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200">
      Could not save. Check your input and try again.
    </p>
  )}

  <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Edit</h2>
    {canEdit ? (
      <form
        method="POST"
        action={`/api/expense-update?id=${eid}&group=${id}`}
        class="flex flex-col gap-3"
        data-dirty-form
      >
        <label class="flex flex-col gap-1 text-sm">
          <span>Description</span>
          <div class="flex items-stretch gap-2">
            <details class="group relative" data-category-picker>
              <summary
                class="flex h-full cursor-pointer list-none items-center justify-center rounded-md border border-neutral-300 bg-white px-3 text-xl leading-none hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-950 dark:hover:bg-neutral-900"
                aria-label="Choose category"
                title="Choose category"
                data-category-emoji
              >
                {currentCategory?.emoji ?? "📌"}
              </summary>
              <div class="absolute left-0 top-full z-10 mt-1 w-56 rounded-md border border-neutral-300 bg-white p-2 shadow-lg dark:border-neutral-700 dark:bg-neutral-950">
                <ul class="flex max-h-64 flex-col gap-0.5 overflow-auto">
                  {categories.map((c) => (
                    <li>
                      <label class="flex cursor-pointer items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-900">
                        <input
                          type="radio"
                          name="category_id"
                          value={c.id}
                          data-category-option
                          data-emoji={c.emoji}
                          checked={c.id === expense.category_id}
                          class="accent-neutral-900 dark:accent-neutral-100"
                        />
                        <span class="text-lg leading-none">{c.emoji}</span>
                        <span>{c.label}</span>
                      </label>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
            <input
              name="description"
              required
              maxlength="200"
              value={expense.description}
              class="flex-1 rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
            />
          </div>
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>Amount ({currency})</span>
          <input
            type="number"
            name="amount_dollars"
            step="0.01"
            min="0.01"
            required
            value={formatCents(expense.amount_cents)}
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
          />
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>Payer</span>
          <select
            name="payer_id"
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950"
          >
            {group.members.map((m) => (
              <option value={m.user_id} selected={m.user_id === expense.payer_id}>
                {m.display_name}
              </option>
            ))}
          </select>
        </label>
        <div class="flex flex-col gap-1 text-sm">
          <span>Split</span>
          <SplitEditor
            members={group.members}
            currency={currency}
            currentUserId={userID}
            initialSplits={expense.splits.map((s) => ({ user_id: s.user_id, share_cents: s.share_cents }))}
          />
        </div>
        <div class="flex items-center justify-end gap-2">
          <DatePicker name="incurred_at" value={incurredAtISO} variant="compact" ariaLabel="Pick date" />
          <button
            type="submit"
            data-dirty-submit
            disabled
            class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:bg-neutral-900 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 dark:disabled:hover:bg-neutral-100"
          >
            Save changes
          </button>
        </div>
        {createdAtDiffers && (
          <p class="text-xs text-neutral-500">
            Recorded on {dateTimeFmt.format(new Date(expense.created_at))}.
          </p>
        )}
        <p class="text-xs text-neutral-500">
          Leave the split as-is to keep current shares (rescaled proportionally if the amount changes).
        </p>
      </form>
    ) : (
      <p class="text-sm text-neutral-500">Only group members can edit this expense.</p>
    )}
  </section>

  <script>
    import "@/scripts/category-picker.ts";
    import "@/scripts/dirty-form.ts";
    import "@/scripts/split-editor.ts";
    import "@/scripts/date-picker.ts";
  </script>

  <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Splits</h2>
    <ul class="flex flex-col gap-1 text-sm">
      {expense.splits.map((s) => {
        const m = memberByID.get(s.user_id);
        return (
          <li class="flex items-center justify-between gap-2">
            <span class="flex items-center gap-2">
              <Avatar
                userId={s.user_id}
                displayName={nameByUserID.get(s.user_id) ?? s.user_id}
                hasAvatar={m?.has_avatar}
                avatarUpdatedAt={m?.avatar_updated_at}
                size={18}
              />
              <span>{nameByUserID.get(s.user_id) ?? s.user_id}</span>
            </span>
            <span class="font-mono">{formatMoney(s.share_cents)}</span>
          </li>
        );
      })}
    </ul>
  </section>

  <section class="mb-8 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">History</h2>
    <ul class="flex flex-col divide-y divide-neutral-200 text-sm dark:divide-neutral-800">
      <li class="flex flex-col gap-1 py-2 first:pt-0 last:pb-0 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between sm:gap-2">
        <span class="font-medium">Created</span>
        <span class="flex items-center gap-1.5 text-xs text-neutral-500">
          <Avatar
            userId={expense.created_by}
            displayName={nameByUserID.get(expense.created_by) ?? "?"}
            hasAvatar={memberByID.get(expense.created_by)?.has_avatar}
            avatarUpdatedAt={memberByID.get(expense.created_by)?.avatar_updated_at}
            size={16}
          />
          <span>{nameByUserID.get(expense.created_by) ?? "?"} · {dateTimeFmt.format(new Date(expense.created_at))}</span>
        </span>
      </li>
      {revisions.map((r) => (
        <li class="flex flex-col gap-1 py-2 first:pt-0 last:pb-0 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between sm:gap-2">
          <span>
            <span class="font-medium">{fieldLabel[r.field] ?? r.field}</span>
            {": "}
            <span class="text-neutral-500 line-through">{renderValue(r.field, r.old_value)}</span>
            {" → "}
            <span>{renderValue(r.field, r.new_value)}</span>
          </span>
          <span class="flex items-center gap-1.5 text-xs text-neutral-500">
            <Avatar
              userId={r.edited_by}
              displayName={nameByUserID.get(r.edited_by) ?? "?"}
              hasAvatar={memberByID.get(r.edited_by)?.has_avatar}
              avatarUpdatedAt={memberByID.get(r.edited_by)?.avatar_updated_at}
              size={16}
            />
            <span>{nameByUserID.get(r.edited_by) ?? "?"} · {dateTimeFmt.format(new Date(r.edited_at))}</span>
          </span>
        </li>
      ))}
    </ul>
  </section>

  {canDelete && (
    <section class="rounded-md border border-red-200 bg-white p-4 dark:border-red-900 dark:bg-neutral-900">
      <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">Danger zone</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Soft-deletes this expense. It will stop affecting balances, but the edit history is kept.
      </p>
      <form
        method="POST"
        action={`/api/expenses/delete?id=${eid}&group=${id}`}
        onsubmit="return confirm('Delete this expense?');"
      >
        <button type="submit" class="rounded-md border border-red-600 bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">
          Delete expense
        </button>
      </form>
    </section>
  )}
</Base>
