---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import BackLink from "@/components/BackLink.astro";
import SplitEditor from "@/components/SplitEditor.astro";
import DatePicker from "@/components/DatePicker.astro";
import ConfirmDialog from "@/components/ConfirmDialog.astro";
import CategoryIcon from "@/components/CategoryIcon.astro";
import FaIcon from "@/components/FaIcon.astro";
import { apiFor } from "@/lib/api/client";

const { id, eid } = Astro.params as { id: string; eid: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, expenseRes, revisionsRes, categoriesRes, recurringRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/expenses/{id}", { params: { path: { id: eid } } }),
  api.GET("/v1/expenses/{id}/revisions", { params: { path: { id: eid } } }),
  api.GET("/v1/categories"),
  api.GET("/v1/groups/{id}/recurring-expenses", { params: { path: { id } } }),
]);

const group = groupsRes.data?.find((g) => g.id === id);
const expense = expenseRes.data;
if (!group || !expense) {
  return Astro.redirect(`/groups/${id}`);
}
const categories = categoriesRes.data ?? [];
const revisions = revisionsRes.data ?? [];
const categoryByID = new Map(categories.map((c) => [c.id, c]));

const currency = expense.currency;
const moneyFmt = new Intl.NumberFormat(undefined, {
  style: "currency",
  currency,
  currencyDisplay: "narrowSymbol",
});
const formatMoney = (cents: number) => moneyFmt.format(cents / 100);
const formatCents = (cents: number) => (cents / 100).toFixed(2);
const dateTimeFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium", timeStyle: "short" });
const dateFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium" });

// "YYYY-MM-DD" form for <input type="date"> using the UTC slice. The create
// flow anchors at noon UTC, so this preserves the user's intended day.
const incurredAtISO = new Date(expense.incurred_at).toISOString().slice(0, 10);
const createdAtDiffers =
  new Date(expense.created_at).toISOString().slice(0, 10) !== incurredAtISO;

// Same content-match heuristic as the group page - flag the expense if a
// recurring template with matching shape exists.
const cadenceLabels: Record<string, string> = {
  daily: "daily",
  weekly: "weekly",
  biweekly: "every 2 weeks",
  monthly: "monthly",
  yearly: "yearly",
};
const matchedTemplate = (recurringRes.data ?? []).find(
  (r) =>
    r.description === expense.description &&
    r.amount_cents === expense.amount_cents &&
    r.payer_id === expense.payer_id &&
    r.currency === expense.currency &&
    r.category_id === expense.category_id,
);
const expenseCadence = matchedTemplate?.cadence;

const userID = Astro.locals.user?.id;
const isMember = group.members.some((m) => m.user_id === userID);
const canEdit = isMember;
const canDelete = isMember;

const nameByUserID = new Map<string, string>();
const memberByID = new Map(group.members.map((m) => [m.user_id, m]));
for (const m of group.members) nameByUserID.set(m.user_id, m.display_name);

const currentCategory = categoryByID.get(expense.category_id);

const showError = Astro.url.searchParams.get("error") === "1";

// Turn a revision's raw old/new value into a reader-friendly label.
function renderValue(field: string, value: string): string {
  if (field === "amount_cents") {
    const n = Number(value);
    return Number.isFinite(n) ? formatMoney(n) : value;
  }
  if (field === "category_id") {
    return categoryByID.get(value)?.label ?? value;
  }
  if (field === "payer_id") {
    return nameByUserID.get(value) ?? value;
  }
  if (field === "splits") {
    try {
      const parsed = JSON.parse(value) as { user_id: string; share_cents: number }[];
      if (!Array.isArray(parsed) || parsed.length === 0) return "-";
      return parsed
        .map((s) => `${nameByUserID.get(s.user_id) ?? s.user_id}: ${formatMoney(s.share_cents)}`)
        .join(", ");
    } catch {
      return value;
    }
  }
  if (field === "incurred_at") {
    const d = new Date(value);
    return Number.isNaN(d.getTime()) ? value : dateFmt.format(d);
  }
  return value;
}
const fieldLabel: Record<string, string> = {
  description: "Description",
  amount_cents: "Amount",
  category_id: "Category",
  payer_id: "Paid by",
  splits: "Splits",
  incurred_at: "Date",
};
---

<Base title={expense.description}>
  <div class="mb-4 flex items-center gap-2">
    <BackLink href={`/groups/${id}`} label={group.name} />
  </div>

  <div class="mb-6 flex items-center gap-3">
    <span class="inline-flex items-center justify-center">
      <CategoryIcon
        slug={currentCategory?.slug}
        groupLabel={currentCategory?.group_label}
        size={40}
      />
    </span>
    <div>
      <div class="flex flex-wrap items-center gap-2">
        <h1 class="text-2xl font-semibold">{expense.description}</h1>
        {expenseCadence && (
          <span
            class="inline-flex items-center gap-1 rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium uppercase tracking-wide text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            title={`Repeats ${cadenceLabels[expenseCadence] ?? expenseCadence}`}
          >
            <FaIcon name="arrows-rotate" size={11} />
            Repeats {cadenceLabels[expenseCadence] ?? expenseCadence}
          </span>
        )}
      </div>
      <p class="flex flex-wrap items-center gap-1.5 text-sm text-neutral-600 dark:text-neutral-400">
        <span>{dateFmt.format(new Date(expense.incurred_at))} · paid by</span>
        <Avatar
          userId={expense.payer_id}
          displayName={nameByUserID.get(expense.payer_id) ?? "?"}
          hasAvatar={memberByID.get(expense.payer_id)?.has_avatar}
          avatarUpdatedAt={memberByID.get(expense.payer_id)?.avatar_updated_at}
          size={18}
        />
        <span>{nameByUserID.get(expense.payer_id) ?? "?"}</span>
        <span>· {formatMoney(expense.amount_cents)}</span>
      </p>
    </div>
  </div>

  {showError && (
    <p
      role="status"
      aria-live="polite"
      class="mb-2 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
    >
      Could not save. Check your input and try again.
    </p>
  )}

  <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Edit</h2>
    {canEdit ? (
      <form
        method="POST"
        action={`/api/expense-update?id=${eid}&group=${id}`}
        class="flex flex-col gap-4"
        data-dirty-form
      >
        <div class="flex items-end gap-2" data-category-picker>
          <input type="hidden" name="category_id" value={expense.category_id} />
          <button
            type="button"
            data-category-open
            aria-label="Choose category"
            title="Choose category"
            class="field-category-trigger"
          >
            <span data-category-icon class="inline-flex items-center justify-center">
              <CategoryIcon
                slug={currentCategory?.slug}
                groupLabel={currentCategory?.group_label}
                size={38}
              />
            </span>
          </button>
          <div class="flex flex-1 flex-col">
            <label class="field">
              <input
                name="description"
                required
                maxlength="200"
                value={expense.description}
                placeholder=" "
                class="field-input"
              />
              <span class="field-label" data-required>What was it?</span>
            </label>
            <p class="field-error">Required</p>
          </div>
          <dialog
            data-category-dialog
            aria-modal="true"
            aria-labelledby="category-dialog-title-edit"
            class="fixed inset-0 m-auto w-[calc(100%-2rem)] max-w-sm rounded-md border border-neutral-200 bg-white p-0 text-neutral-900 shadow-xl backdrop:bg-neutral-900/40 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
          >
            <div class="flex flex-col gap-3 p-5">
              <div class="flex items-center justify-between gap-3">
                <h3 id="category-dialog-title-edit" class="text-lg font-medium">Choose category</h3>
                <button
                  type="button"
                  data-category-cancel
                  aria-label="Close"
                  title="Close"
                  class="rounded-md px-2 py-1 text-sm text-neutral-600 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:focus-visible:ring-neutral-500"
                >
                  <FaIcon name="xmark" size={14} />
                </button>
              </div>
              <ul class="flex max-h-[60vh] flex-col gap-0.5 overflow-auto">
                {categories.map((c, i) => (
                  <>
                    {(i === 0 || categories[i - 1].group_label !== c.group_label) && (
                      <li class="field-category-group" role="presentation">{c.group_label}</li>
                    )}
                    <li>
                      <button
                        type="button"
                        data-category-option
                        data-category-id={c.id} 
                        data-slug={c.slug}
                        data-group-label={c.group_label}
                        class="field-category-option"
                      >
                        <CategoryIcon slug={c.slug} groupLabel={c.group_label} size={28} />
                        <span>{c.label}</span>
                      </button>
                    </li>
                  </>
                ))}
              </ul>
            </div>
          </dialog>
        </div>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <label class="field">
              <input type="hidden" name="amount_dollars" value={formatCents(expense.amount_cents)} />
              <input
                type="text"
                inputmode="decimal"
                pattern="[0-9.,]+"
                data-currency-input
                data-currency-hidden="amount_dollars"
                data-currency={currency}
                required
                value={formatCents(expense.amount_cents)}
                placeholder=" "
                class="field-input field-input-currency"
              />
              <span class="field-label" data-required>Amount ({currency})</span>
            </label>
            <p class="field-error">Enter an amount greater than 0</p>
          </div>
          <label class="field-select-row">
            <span>Paid by</span>
            <select name="payer_id" class="field-select">
              {group.members.map((m) => (
                <option value={m.user_id} selected={m.user_id === expense.payer_id}>
                  {m.display_name}
                </option>
              ))}
            </select>
          </label>
        </div>
        <SplitEditor
          members={group.members}
          currency={currency}
          currentUserId={userID}
          initialSplits={expense.splits.map((s) => ({ user_id: s.user_id, share_cents: s.share_cents }))}
        />
        <div class="flex items-center justify-end gap-2">
          <DatePicker
            name="incurred_at"
            value={incurredAtISO}
            variant="compact"
            ariaLabel="Pick date"
            weekStart={Astro.locals.user?.week_start === 0 ? 0 : 1}
          />
          <button type="submit" data-dirty-submit disabled class="btn-primary">Save changes</button>
        </div>
        {createdAtDiffers && (
          <p class="text-xs text-neutral-600 dark:text-neutral-400">
            Recorded on {dateTimeFmt.format(new Date(expense.created_at))}.
          </p>
        )}
        <p class="text-xs text-neutral-600 dark:text-neutral-400">
          Leave the split as-is to keep current shares (rescaled proportionally if the amount changes).
        </p>
      </form>
    ) : (
      <p class="text-sm text-neutral-500">Only group members can edit this expense.</p>
    )}
  </section>

  <script>
    import "@/scripts/category-picker.ts";
    import "@/scripts/dirty-form.ts";
    import "@/scripts/split-editor.ts";
    import "@/scripts/date-picker.ts";
    import "@/scripts/confirm-dialog.ts";
    import "@/scripts/currency-input.ts";
  </script>

  <div class="mb-4 grid grid-cols-1 gap-4 md:grid-cols-2">
    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">Splits</h2>
      <ul class="flex flex-col gap-2 text-sm">
        {expense.splits.map((s) => {
          const m = memberByID.get(s.user_id);
          return (
            <li class="flex items-center justify-between gap-2">
              <span class="flex min-w-0 items-center gap-2">
                <Avatar
                  userId={s.user_id}
                  displayName={nameByUserID.get(s.user_id) ?? s.user_id}
                  hasAvatar={m?.has_avatar}
                  avatarUpdatedAt={m?.avatar_updated_at}
                  size={18}
                />
                <span class="truncate">{nameByUserID.get(s.user_id) ?? s.user_id}</span>
              </span>
              <span class="shrink-0 font-mono">{formatMoney(s.share_cents)}</span>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 font-medium">History</h2>
      <ul class="flex flex-col divide-y divide-neutral-200 text-sm dark:divide-neutral-800">
        <li class="flex flex-col gap-1 py-2 first:pt-0 last:pb-0 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between sm:gap-2">
          <span class="font-medium">Created</span>
          <span class="flex items-center gap-1.5 text-xs text-neutral-600 dark:text-neutral-400">
            <Avatar
              userId={expense.created_by}
              displayName={nameByUserID.get(expense.created_by) ?? "?"}
              hasAvatar={memberByID.get(expense.created_by)?.has_avatar}
              avatarUpdatedAt={memberByID.get(expense.created_by)?.avatar_updated_at}
              size={16}
            />
            <span>{nameByUserID.get(expense.created_by) ?? "?"} · {dateTimeFmt.format(new Date(expense.created_at))}</span>
          </span>
        </li>
        {revisions.map((r) => (
          <li class="flex flex-col gap-1 py-2 first:pt-0 last:pb-0 sm:flex-row sm:flex-wrap sm:items-baseline sm:justify-between sm:gap-2">
            <span>
              <span class="font-medium">{fieldLabel[r.field] ?? r.field}</span>
              {": "}
              <span class="text-neutral-600 line-through dark:text-neutral-400">{renderValue(r.field, r.old_value)}</span>
              <span class="mx-1 inline-flex text-neutral-500">
                <FaIcon name="arrow-right" size={11} />
              </span>
              <span>{renderValue(r.field, r.new_value)}</span>
            </span>
            <span class="flex items-center gap-1.5 text-xs text-neutral-600 dark:text-neutral-400">
              <Avatar
                userId={r.edited_by}
                displayName={nameByUserID.get(r.edited_by) ?? "?"}
                hasAvatar={memberByID.get(r.edited_by)?.has_avatar}
                avatarUpdatedAt={memberByID.get(r.edited_by)?.avatar_updated_at}
                size={16}
              />
              <span>{nameByUserID.get(r.edited_by) ?? "?"} · {dateTimeFmt.format(new Date(r.edited_at))}</span>
            </span>
          </li>
        ))}
      </ul>
    </section>
  </div>

  {canDelete && (
    <section class="rounded-md border border-red-200 bg-white p-4 dark:border-red-900 dark:bg-neutral-900">
      <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">Danger zone</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Soft-deletes this expense. It will stop affecting balances, but the edit history is kept.
      </p>
      <form
        method="POST"
        action={`/api/expenses/delete?id=${eid}&group=${id}`}
        class="flex justify-end"
      >
        <button type="button" data-confirm-open="confirm-delete-expense" class="btn-danger">Delete expense</button>
      </form>
      <ConfirmDialog
        id="confirm-delete-expense"
        title="Delete this expense?"
        message="It will stop affecting balances, but the edit history is kept. This cannot be undone from the UI."
        confirmLabel="Delete expense"
      />
    </section>
  )}
</Base>
