---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import ConfirmDialog from "@/components/ConfirmDialog.astro";
import CategoryIcon from "@/components/CategoryIcon.astro";
import FaIcon from "@/components/FaIcon.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, recurringRes, categoriesRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/groups/{id}/recurring-expenses", { params: { path: { id } } }),
  api.GET("/v1/categories"),
]);

const group = groupsRes.data?.find((g) => g.id === id);
if (!group) {
  return Astro.redirect("/groups");
}
const templates = recurringRes.data ?? [];
const categories = categoriesRes.data ?? [];
const categoryByID = new Map(categories.map((c) => [c.id, c]));

const nameByUserID = new Map<string, string>();
const memberByID = new Map(group.members.map((m) => [m.user_id, m]));
for (const m of group.members) nameByUserID.set(m.user_id, m.display_name);

const cadenceLabels: Record<string, string> = {
  daily: "Daily",
  weekly: "Weekly",
  biweekly: "Every 2 weeks",
  monthly: "Monthly",
  yearly: "Yearly",
};
const dateFmt = new Intl.DateTimeFormat(undefined, { dateStyle: "medium" });

const showError = Astro.url.searchParams.get("error") === "1";
---

<Base title={`${group.name} - recurring`} back={{ href: `/groups/${id}`, label: group.name }}>
  <h1 class="mb-4 text-2xl font-semibold">Recurring expenses</h1>

  {showError && (
    <p
      role="status"
      aria-live="polite"
      class="mb-4 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
    >
      Could not stop the template. Try again.
    </p>
  )}

  {templates.length === 0 ? (
    <div class="rounded-md border border-neutral-200 bg-white p-6 text-sm dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-2 font-medium">No recurring expenses yet</h2>
      <p class="text-neutral-600 dark:text-neutral-400">
        Add a regular expense in <a href={`/groups/${id}`} class="underline">{group.name}</a> and
        pick a repeat cadence in the date picker to create one.
      </p>
    </div>
  ) : (
    <>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Stopping a template only cancels future runs. Expenses already created from it stay in place.
      </p>
      <ul class="flex flex-col gap-2">
      {templates.map((t) => {
        const cat = categoryByID.get(t.category_id);
        const moneyFmt = new Intl.NumberFormat(undefined, {
          style: "currency",
          currency: t.currency,
          currencyDisplay: "narrowSymbol",
        });
        return (
          <li class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
            <div class="flex items-start justify-between gap-3">
              <div class="flex min-w-0 items-center gap-3">
                <span class="inline-flex items-center justify-center" title={cat?.label ?? ""}>
                  <CategoryIcon slug={cat?.slug} groupLabel={cat?.group_label} size={28} />
                </span>
                <div class="flex min-w-0 flex-col gap-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="truncate font-medium">{t.description}</span>
                    <span class="inline-flex items-center gap-1 rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium uppercase tracking-wide text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200">
                      <FaIcon name="arrows-rotate" size={11} />
                      {cadenceLabels[t.cadence] ?? t.cadence}
                    </span>
                  </div>
                  <div class="flex flex-wrap items-center gap-1.5 text-xs text-neutral-600 dark:text-neutral-400">
                    <span>Paid by</span>
                    <Avatar
                      userId={t.payer_id}
                      displayName={nameByUserID.get(t.payer_id) ?? "?"}
                      hasAvatar={memberByID.get(t.payer_id)?.has_avatar}
                      avatarUpdatedAt={memberByID.get(t.payer_id)?.avatar_updated_at}
                      size={16}
                    />
                    <span>{nameByUserID.get(t.payer_id) ?? "?"}</span>
                    <span>· next on {dateFmt.format(new Date(t.next_run_at))}</span>
                  </div>
                </div>
              </div>
              <div class="flex shrink-0 flex-col items-end gap-1.5">
                <span class="font-mono text-sm">{moneyFmt.format(t.amount_cents / 100)}</span>
                <form
                  method="POST"
                  action={`/api/recurring-delete?id=${t.id}&group=${id}`}
                >
                  <button
                    type="button"
                    data-confirm-open={`confirm-stop-${t.id}`}
                    class="btn-danger-outline btn-sm"
                  >
                    Stop
                  </button>
                </form>
                <ConfirmDialog
                  id={`confirm-stop-${t.id}`}
                  title="Stop this recurring template?"
                  message="Past expenses already created from this template stay in place. Only future runs are cancelled."
                  confirmLabel="Stop template"
                />
              </div>
            </div>
          </li>
        );
      })}
      </ul>
    </>
  )}

  <script>
    import "@/scripts/confirm-dialog.ts";
  </script>
</Base>
