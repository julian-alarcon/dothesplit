---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import ConfirmDialog from "@/components/ConfirmDialog.astro";
import { apiFor } from "@/lib/api/client";
import { COMMON_CURRENCIES, otherCurrencies, currencyLabel } from "@/lib/currencies";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const [groupsRes, balancesRes, activityRes] = await Promise.all([
  api.GET("/v1/groups"),
  api.GET("/v1/groups/{id}/balances", { params: { path: { id } } }),
  api.GET("/v1/groups/{id}/activity", { params: { path: { id }, query: { limit: 1 } } }),
]);
const group = groupsRes.data?.find((g) => g.id === id);
if (!group) {
  return Astro.redirect("/groups");
}
// The currency is locked once the ledger has any expense or settlement -
// changing it after that would silently reinterpret stored amount_cents.
const currencyLocked = (activityRes.data?.items?.length ?? 0) > 0;

const currency = group.default_currency;
const isCreator = group.created_by === Astro.locals.user?.id;

const myID = Astro.locals.user?.id ?? "";
const myNetCents =
  balancesRes.data?.net?.find((b) => b.user_id === myID)?.net_cents ?? 0;
const myMoneyFmt = new Intl.NumberFormat(undefined, {
  style: "currency",
  currency,
  currencyDisplay: "narrowSymbol",
});

const isPair = group.members.length === 2;
const pairMembers = isPair ? group.members : [];
const defaultSplit = group.default_split ?? [];
const hasDefaultSplit = defaultSplit.length === 2;
const dsBPByUser = new Map<string, number>();
for (const e of defaultSplit) dsBPByUser.set(e.user_id, e.basis_points);
const pairPrefill = pairMembers.map((m) => ({
  member: m,
  percent: ((dsBPByUser.get(m.user_id) ?? 5000) / 100).toString(),
}));

const showSettingsError = Astro.url.searchParams.get("error") === "1";
const errorReason = Astro.url.searchParams.get("reason") ?? "";
const locale = Astro.locals.locale;
const others = otherCurrencies();
---

<Base title={`${group.name} - settings`} back={{ href: `/groups/${id}`, label: group.name }}>
  <h1 class="mb-2 text-2xl font-semibold">Group settings</h1>
  <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
    {group.members.length} member{group.members.length === 1 ? "" : "s"} · default currency {currency}
  </p>

  {showSettingsError && (
    <p
      role="status"
      aria-live="polite"
      class="mb-2 rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
    >
      {errorReason ? errorReason : "Could not update the group. Check your input and try again."}
    </p>
  )}

  <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Rename &amp; currency</h2>
    <form method="POST" action={`/api/group-settings?id=${id}`} class="flex flex-col gap-3">
      <label class="field">
        <input
          name="name"
          required
          minlength="1"
          maxlength="80"
          value={group.name}
          placeholder=" "
          class="field-input"
        />
        <span class="field-label" data-required>Group name</span>
      </label>
      <p class="field-error">Required</p>
      <label class="field-select-row">
        <span>Default currency</span>
        <select
          name="default_currency"
          class="field-select"
          disabled={currencyLocked}
          aria-describedby={currencyLocked ? "currency-lock-hint" : undefined}
        >
          <optgroup label="Common">
            {COMMON_CURRENCIES.map((c) => (
              <option value={c} selected={c === currency}>{currencyLabel(c, locale)}</option>
            ))}
          </optgroup>
          <optgroup label="All currencies">
            {others.map((c) => (
              <option value={c} selected={c === currency}>{currencyLabel(c, locale)}</option>
            ))}
          </optgroup>
        </select>
      </label>
      {currencyLocked && (
        <p id="currency-lock-hint" class="-mt-1 text-xs text-neutral-600 dark:text-neutral-400">
          Currency is fixed after the first expense or settlement. To change it, delete all activity or create a new group.
        </p>
      )}
      <button type="submit" class="btn-primary mt-1 self-end">Save</button>
    </form>
  </section>

  <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Members</h2>
    <ul class="mb-3 flex flex-col gap-2 text-sm">
      {group.members.map((m) => {
        const isThisCreator = m.user_id === group.created_by;
        const canRemove = isCreator && !isThisCreator;
        return (
          <li class="flex items-center justify-between gap-2">
            <span class="flex min-w-0 items-center gap-2">
              <Avatar
                userId={m.user_id}
                displayName={m.display_name}
                hasAvatar={m.has_avatar}
                avatarUpdatedAt={m.avatar_updated_at}
                size={20}
              />
              <span class="truncate">{m.display_name}</span>
            </span>
            <span class="flex shrink-0 items-center gap-2">
              {isThisCreator && (
                <span class="text-xs uppercase tracking-wide text-neutral-600 dark:text-neutral-400">creator</span>
              )}
              {canRemove && (
                <>
                  <form method="POST" action={`/api/group-member-remove?id=${id}`}>
                    <input type="hidden" name="user_id" value={m.user_id} />
                    <button
                      type="button"
                      data-confirm-open={`confirm-remove-${m.user_id}`}
                      class="btn-danger-outline btn-sm"
                    >
                      Remove
                    </button>
                  </form>
                  <ConfirmDialog
                    id={`confirm-remove-${m.user_id}`}
                    title={`Remove ${m.display_name}?`}
                    message="Their past expenses, splits and settlements stay in the group ledger. They can be re-added later."
                    confirmLabel="Remove member"
                  />
                </>
              )}
            </span>
          </li>
        );
      })}
    </ul>
    {isPair && hasDefaultSplit && (
      <p class="mb-2 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-xs text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-200">
        Adding a 3rd member will clear the pinned default split. New expenses will fall back to an equal split until you set a new default.
      </p>
    )}
    <form
      method="POST"
      action={`/api/group-members?id=${id}`}
      class="flex items-end gap-2"
    >
      <div class="flex flex-1 flex-col">
        <label class="field">
          <input
            type="email"
            name="email"
            placeholder=" "
            required
            class="field-input"
          />
          <span class="field-label" data-required>New member email</span>
        </label>
        <p class="field-error">Enter a valid email address</p>
      </div>
      <button type="submit" class="btn-primary">Add</button>
    </form>
    <p class="mt-1 text-xs text-neutral-600 dark:text-neutral-400">The invitee must already be registered.</p>
  </section>

  <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
    <h2 class="mb-3 font-medium">Default split</h2>
    <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
      {!isPair
        ? "Only available for 2-member groups. New expenses default to an equal split."
        : hasDefaultSplit
          ? "New expenses prefill with this percentage split. The split editor still lets you change it per-expense."
          : "Pin a percentage split (e.g. 60/40) to prefill new expenses. Cleared automatically if a 3rd member joins."}
    </p>
    <fieldset disabled={!isPair} class="contents">
      <form
        method="POST"
        action={`/api/group-default-split?id=${id}`}
        class="flex flex-col gap-2"
      >
        <input type="hidden" name="action" value="set" />
        {(isPair ? pairPrefill : group.members.slice(0, 2).map((m) => ({ member: m, percent: "50" }))).map((p, i) => (
          <div class="flex items-center gap-2 text-sm">
            <span class="flex-1">{p.member.display_name}</span>
            <input type="hidden" name={`member_id_${i + 1}`} value={p.member.user_id} />
            <input
              type="number"
              name={`percent_${i + 1}`}
              step="0.01"
              min="0"
              max="100"
              required
              value={p.percent}
              disabled={!isPair}
              class="field-input-num w-20"
            />
            <span class="text-neutral-600 dark:text-neutral-400">%</span>
          </div>
        ))}
        <p class="text-xs text-neutral-600 dark:text-neutral-400">Must sum to 100.</p>
        <div class="flex justify-end gap-2">
          <button type="submit" disabled={!isPair} class="btn-primary btn-sm">
            {hasDefaultSplit ? "Update default" : "Pin default"}
          </button>
        </div>
      </form>
      {hasDefaultSplit && isPair && (
        <form
          method="POST"
          action={`/api/group-default-split?id=${id}`}
          class="mt-2 flex justify-end"
        >
          <input type="hidden" name="action" value="clear" />
          <button type="submit" class="btn-secondary btn-sm">Clear default</button>
        </form>
      )}
    </fieldset>
  </section>

  {!isCreator && (
    <section class="mb-2 rounded-md border border-red-200 bg-white p-4 dark:border-red-900 dark:bg-neutral-900">
      <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">Leave group</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Removes you from this group. Your past expenses, splits, and settlements stay in the ledger.
      </p>
      {myNetCents !== 0 && (
        <p class="mb-3 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-200">
          You have a non-zero balance of <span class="font-mono">{myMoneyFmt.format(myNetCents / 100)}</span> in this group. Leaving without settling up means
          {myNetCents > 0
            ? " others won't be reminded to pay you back."
            : " you won't be reminded to pay your share."}
          Consider settling up first.
        </p>
      )}
      <form
        method="POST"
        action={`/api/group-member-remove?id=${id}`}
        class="flex justify-end"
      >
        <input type="hidden" name="user_id" value={myID} />
        <input type="hidden" name="leave" value="1" />
        <button type="submit" class="btn-danger">Leave group</button>
      </form>
    </section>
  )}

  {isCreator && group.members.length > 1 && (
    <section class="mb-2 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-2 font-medium">Transfer ownership</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Hand the group to another member. You stay in the group as a regular member, and the new owner takes over creator-only powers (transfer, delete, remove members).
      </p>
      <form
        method="POST"
        action={`/api/group-transfer-ownership?id=${id}`}
        class="flex flex-col gap-2 sm:flex-row sm:items-end"
      >
        <label class="field-select-row sm:flex-1">
          <span>New owner <span class="text-red-600">*</span></span>
          <select name="new_owner_id" required class="field-select">
            {group.members
              .filter((m) => m.user_id !== group.created_by)
              .map((m) => (
                <option value={m.user_id}>{m.display_name}</option>
              ))}
          </select>
        </label>
        <button type="button" data-confirm-open="confirm-transfer-ownership" class="btn-primary">Transfer</button>
      </form>
      <ConfirmDialog
        id="confirm-transfer-ownership"
        title="Transfer ownership?"
        message="The selected member becomes the new owner. You will keep being a regular member of the group."
        confirmLabel="Transfer ownership"
        confirmVariant="primary"
      />
    </section>
  )}

  {isCreator && (
    <section class="rounded-md border border-red-200 bg-white p-4 dark:border-red-900 dark:bg-neutral-900">
      <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-red-600 dark:text-red-400">Danger zone</h2>
      <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
        Deleting the group removes all its expenses, settlements and recurring templates. This cannot be undone.
      </p>
      <form method="POST" action={`/api/group-delete?id=${id}`} class="flex justify-end">
        <button type="button" data-confirm-open="confirm-delete-group" class="btn-danger">Delete group</button>
      </form>
      <ConfirmDialog
        id="confirm-delete-group"
        title="Delete this group?"
        message="All expenses, settlements and recurring templates in this group are removed permanently. This cannot be undone."
        confirmLabel="Delete group"
      />
    </section>
  )}

  <script>
    import "@/scripts/confirm-dialog.ts";
  </script>
</Base>
