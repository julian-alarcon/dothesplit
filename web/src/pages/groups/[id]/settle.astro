---
import Base from "@/layouts/Base.astro";
import Avatar from "@/components/Avatar.astro";
import { apiFor } from "@/lib/api/client";

const { id } = Astro.params as { id: string };
const api = apiFor(Astro.locals.cookie);

const { data: groups } = await api.GET("/v1/groups");
const group = groups?.find((g) => g.id === id);
if (!group) return Astro.redirect("/groups");

const currency = group.default_currency;
const me = Astro.locals.user;
const payees = group.members.filter((m) => m.user_id !== me?.id);
const showError = Astro.url.searchParams.get("error") === "1";
---

<Base title={`Settle up · ${group.name}`}>
  <div class="mx-auto flex max-w-xl flex-col gap-6">
    <div class="flex items-center gap-2 text-sm">
      <a href={`/groups/${id}`} class="text-neutral-600 hover:underline dark:text-neutral-400">← Back to {group.name}</a>
    </div>

    <div>
      <h1 class="text-2xl font-semibold">Settle up</h1>
      <p class="text-sm text-neutral-600 dark:text-neutral-400">Record a payment from you to another member of {group.name}.</p>
    </div>

    {showError && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-200"
      >
        Could not record the settlement. Check the amount and recipient and try again.
      </p>
    )}

    {payees.length === 0 ? (
      <p class="rounded-md border border-neutral-200 bg-white p-4 text-sm text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
        You're the only member of this group, so there's nobody to settle up with yet. Add someone under
        <a href={`/groups/${id}/settings`} class="underline"> Group settings</a>.
      </p>
    ) : (
      <form
        method="POST"
        action={`/api/settlements?id=${id}`}
        class="flex flex-col gap-4 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
      >
        <label class="flex flex-col gap-1 text-sm">
          <span>Pay to</span>
          <select
            name="to_user_id"
            required
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm dark:border-neutral-700 dark:bg-neutral-950"
          >
            <option value="">Pick a member…</option>
            {payees.map((m) => (
              <option value={m.user_id}>{m.display_name}</option>
            ))}
          </select>
        </label>

        <label class="flex flex-col gap-1 text-sm">
          <span>Amount ({currency})</span>
          <input
            type="number"
            name="amount_dollars"
            step="0.01"
            min="0.01"
            required
            placeholder={`0.00 ${currency}`}
            class="rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm dark:border-neutral-700 dark:bg-neutral-950"
          />
        </label>

        <div class="flex items-center justify-end gap-2">
          <a
            href={`/groups/${id}`}
            class="rounded-md border border-neutral-300 px-4 py-2 text-sm font-medium hover:bg-neutral-50 dark:border-neutral-700 dark:hover:bg-neutral-800"
          >
            Cancel
          </a>
          <button
            type="submit"
            class="rounded-md bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300"
          >
            Record payment
          </button>
        </div>
      </form>
    )}

    <section class="rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-600 dark:text-neutral-400">Members you can pay</h2>
      {payees.length === 0 ? (
        <p class="text-sm text-neutral-500">No other members.</p>
      ) : (
        <ul class="flex flex-col gap-2 text-sm">
          {payees.map((m) => (
            <li class="flex items-center gap-2">
              <Avatar
                userId={m.user_id}
                displayName={m.display_name}
                hasAvatar={m.has_avatar}
                avatarUpdatedAt={m.avatar_updated_at}
                size={20}
              />
              <span>{m.display_name}</span>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</Base>
