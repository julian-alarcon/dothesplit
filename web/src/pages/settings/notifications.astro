---
import Base from "@/layouts/Base.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const internalBase =
  process.env.API_BASE_URL_INTERNAL ?? "http://localhost:8080";

// Server-render the current values by calling the API with the same cookie.
const cookie = Astro.request.headers.get("cookie") ?? "";
type Prefs = {
  notify_recurring_run?: boolean;
  notify_settlement?: boolean;
  notify_group_added?: boolean;
};
let prefs: Prefs = {};
try {
  const res = await fetch(`${internalBase}/v1/me/notifications`, {
    headers: { cookie },
  });
  if (res.ok) {
    prefs = (await res.json()) as Prefs;
  }
} catch {
  // Soft-fail - the form still renders with defaults.
}

const ok = Astro.url.searchParams.get("ok");
---

<Base title="Notifications" back={{ href: "/account", label: "Account" }}>
  <div class="mx-auto flex max-w-xl flex-col gap-3">
    <h1 class="text-2xl font-semibold">Notifications</h1>
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      Pick what should reach you. Defaults are off - opt in to anything you want to hear about.
    </p>

    {ok === "saved" && (
      <p
        role="status"
        aria-live="polite"
        class="rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200"
      >
        Preferences saved.
      </p>
    )}

    <form
      method="POST"
      action="/api/me-notifications"
      class="flex flex-col gap-4 rounded-md border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900"
    >
      <h2 class="text-sm font-medium uppercase tracking-wide text-neutral-600 dark:text-neutral-400">
        Email
      </h2>

      <label class="toggle">
        <input
          type="checkbox"
          name="notify_recurring_run"
          value="1"
          class="toggle-input"
          checked={prefs.notify_recurring_run === true}
        />
        <span class="toggle-track" aria-hidden="true"></span>
        <span>A recurring expense is added to one of my groups</span>
      </label>

      <label class="toggle">
        <input
          type="checkbox"
          name="notify_settlement"
          value="1"
          class="toggle-input"
          checked={prefs.notify_settlement === true}
        />
        <span class="toggle-track" aria-hidden="true"></span>
        <span>A settlement is recorded in one of my groups</span>
      </label>

      <label class="toggle">
        <input
          type="checkbox"
          name="notify_group_added"
          value="1"
          class="toggle-input"
          checked={prefs.notify_group_added === true}
        />
        <span class="toggle-track" aria-hidden="true"></span>
        <span>I am added to a new group</span>
      </label>

      <div class="flex justify-end pt-2">
        <button type="submit" class="btn-primary">Save preferences</button>
      </div>
    </form>
  </div>
</Base>
